{
  "name": "mk",
  "type": "module",
  "version": "6.0.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "build:analyze": "astro build --analyze",
    "build:clean": "rm -rf dist .astro && astro build",
    "build:optimized": "npm run build && npm run optimize:all",
    "preview": "astro preview",
    "blog:thumbs": "node scripts/generate-blog-thumbnails.mjs",
    "test:chat": "node scripts/test-chat.mjs",
    "astro": "astro",
    "deploy": "./deploy.sh",
    "deploy:production": "./deploy.sh production",
    "size:check": "du -sh dist/ && find dist/ -type f -name '*.js' -o -name '*.css' -o -name '*.html' | head -10 | xargs du -h | sort -hr"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/sitemap": "^3.7.3",
    "@microsoft/clarity": "^1.0.2",
    "astro": "^7.0.6",
    "swiper": "^12.0.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.2",
    "web-vitals": "^5.0.3"
  },
  "devDependencies": {
    "@astrojs/cloudflare": "^14.1.1",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.4.49",
    "terser": "^5.43.1",
    "vite-bundle-analyzer": "^1.1.0",
    "wrangler": "^4.30.0"
  },
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10.0.0"
  }
}
