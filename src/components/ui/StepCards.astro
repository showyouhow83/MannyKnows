---
// Shared "how it works" step cards — the single source of truth for the
// numbered-step card style used across the site (homepage idea→app, AI Team,
// plan detail, free-360, free AI analysis). Gradient icon tile + big faint
// watermark number (via CSS ::after, so the decorative digit doesn't trip
// color-contrast) + lift-on-hover.
//
// Steps without an `icon` fall back to a generic kickoff→build→launch→iterate
// icon set; steps without `n` are numbered by position (zero-padded).
interface Step {
  n?: string;
  title: string;
  body: string;
  icon?: string;
}
interface Props {
  steps: Step[];
  cols?: 3 | 4 | 5;
  class?: string;
}
const { steps, cols = 4, class: className = 'max-w-6xl mx-auto' } = Astro.props;

const FALLBACK_ICONS = [
  'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.9 9.9 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z',
  'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4',
  'M13 10V3L4 14h7v7l9-11h-7z',
  'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15',
];
const colsCls = cols === 3 ? 'md:grid-cols-3' : cols === 5 ? 'sm:grid-cols-2 lg:grid-cols-5' : 'sm:grid-cols-2 lg:grid-cols-4';
---

<div class={`grid grid-cols-1 ${colsCls} gap-5 ${className}`}>
  {steps.map((s, i) => (
    <div class="group relative overflow-hidden rounded-2xl border border-light-tertiary dark:border-dark-accent bg-white dark:bg-dark-secondary p-6 transition-all duration-300 hover:border-primary-blue/40 hover:shadow-xl hover:shadow-primary-blue/10">
      <span aria-hidden="true" data-n={s.n ?? String(i + 1).padStart(2, '0')} class="pointer-events-none absolute top-3 right-4 text-6xl font-black leading-none text-primary-blue/10 dark:text-blue-300/10 select-none after:content-[attr(data-n)]"></span>
      <div class="relative flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-primary-blue to-primary-pink text-white shadow-lg shadow-primary-blue/20">
        <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d={s.icon ?? FALLBACK_ICONS[i % FALLBACK_ICONS.length]} />
        </svg>
      </div>
      <h3 class="relative mt-4 text-lg font-bold text-text-light-primary dark:text-text-dark-primary">{s.title}</h3>
      <p class="relative mt-2 text-sm text-text-light-secondary dark:text-text-dark-secondary leading-relaxed">{s.body}</p>
    </div>
  ))}
</div>
