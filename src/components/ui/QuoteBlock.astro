---
// Testimonial card for embedding proof on high-intent pages. Pass a Testimonial
// from src/data/testimonials.ts. Renders nothing if none is given.
// Redesigned: gradient-ring card, avatar with initial, 5-star row, quote mark.
import type { Testimonial } from '../../data/testimonials';

interface Props {
  quote?: Testimonial;
  align?: 'left' | 'center';
  class?: string;
}
const { quote, align = 'left', class: className = '' } = Astro.props;
const initial = quote ? (quote.business || quote.name).trim().charAt(0).toUpperCase() : '';
const centered = align === 'center';
---

{quote && (
  <figure class={`group relative rounded-3xl p-[1.5px] bg-gradient-to-br from-primary-blue/40 via-purple-500/20 to-primary-pink/40 ${className}`}>
    <div class={`relative flex h-full flex-col rounded-3xl bg-white dark:bg-dark-secondary p-6 md:p-8 overflow-hidden ${centered ? 'text-center' : ''}`}>
      <!-- watermark quote glyph — kept fully inside the card so it never clips -->
      <span aria-hidden="true" class="pointer-events-none absolute top-3 right-5 text-[5.5rem] leading-none font-serif text-primary-blue/[0.07] dark:text-blue-300/[0.09] select-none">”</span>

      <!-- star rating -->
      <div class={`relative flex gap-1 mb-4 ${centered ? 'justify-center' : ''}`} aria-label="5 out of 5 stars">
        {[0, 1, 2, 3, 4].map(() => (
          <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.286 3.958a1 1 0 00.95.69h4.162c.969 0 1.371 1.24.588 1.81l-3.368 2.447a1 1 0 00-.364 1.118l1.287 3.958c.3.922-.755 1.688-1.54 1.118l-3.367-2.447a1 1 0 00-1.176 0l-3.367 2.447c-.784.57-1.838-.196-1.539-1.118l1.286-3.958a1 1 0 00-.363-1.118L2.075 9.385c-.783-.57-.38-1.81.588-1.81h4.162a1 1 0 00.951-.69l1.286-3.958z"/></svg>
        ))}
      </div>

      <blockquote class="relative flex-1 text-[15px] md:text-[17px] text-text-light-primary dark:text-text-dark-primary leading-relaxed">
        {quote.quote}
      </blockquote>

      <figcaption class={`mt-5 pt-5 border-t border-light-tertiary dark:border-dark-accent flex items-center gap-3 ${centered ? 'justify-center' : ''}`}>
        <span class="flex h-11 w-11 flex-shrink-0 items-center justify-center rounded-full bg-gradient-to-br from-primary-blue to-primary-pink text-white font-bold text-lg shadow-md shadow-primary-blue/20" aria-hidden="true">{initial}</span>
        <span class="text-left">
          <span class="block text-sm font-bold text-text-light-primary dark:text-text-dark-primary leading-tight">
            {quote.name}{quote.role ? <span class="font-normal text-text-light-tertiary dark:text-text-dark-tertiary">, {quote.role}</span> : null}
          </span>
          {quote.href ? (
            <a href={quote.href} class="text-sm text-primary-blue dark:text-blue-300 font-medium hover:underline">{quote.business} →</a>
          ) : (
            <span class="text-sm text-text-light-secondary dark:text-text-dark-secondary">{quote.business}</span>
          )}
        </span>
      </figcaption>
    </div>
  </figure>
)}
