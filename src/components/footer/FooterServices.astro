---
// Footer Services Section - Collection of all service categories
import ServiceCategory from './ServiceCategory.astro';

// Service categories data — curated to the services that actually win business
// for local + eCommerce clients, and linked to the most relevant real page (no
// more thin, unlinked keyword lists). Column layout (balanced, 2 groups max per
// column): 1) Web & Apps → SEO & Marketing, 2) eCommerce, 3) Automation →
// AI Content, 4) Photo & Video → 360°.
const serviceCategories = [
  // Column 1: Web & Apps (+ SEO & Marketing + AI Content)
  {
    title: "Web & Apps",
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
      <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
      <line x1="8" y1="21" x2="16" y2="21"></line>
      <line x1="12" y1="17" x2="12" y2="21"></line>
    </svg>`,
    iconGradient: "from-slate-500 to-gray-500",
    textColor: "text-slate-400",
    borderColor: "border-slate-300/30 dark:border-slate-400/20",
    backgroundGradient: "from-slate-500/10 via-gray-500/5 to-slate-600/10",
    roundedClass: "rounded-tl-lg",
    services: [
      { href: "/services", label: "Website Design" },
      { href: "/products", label: "Custom Web Apps" },
      { href: "/plans/smart-website", label: "AI Booking Agents" }
    ],
    hasSecondarySection: true,
    secondaryTitle: "SEO & Marketing",
    secondaryIcon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
      <line x1="18" y1="20" x2="18" y2="10"></line>
      <line x1="12" y1="20" x2="12" y2="4"></line>
      <line x1="6" y1="20" x2="6" y2="14"></line>
    </svg>`,
    secondaryIconGradient: "from-orange-500 to-yellow-500",
    secondaryTextColor: "text-orange-400",
    secondaryServices: [
      { href: "/services", label: "Local SEO" },
      { href: "/services", label: "Google Business Profile" },
      { href: "/services", label: "Competitor Analysis" }
    ]
  },

  // Column 2: eCommerce
  {
    title: "eCommerce",
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
      <path d="M3 3h2l.4 2M7 13h10l4-8H5.4m0 0L7 13m0 0l-2.293 2.293c-.63.63-.184 1.707.707 1.707H19M17 21a2 2 0 100-4 2 2 0 000 4zM9 21a2 2 0 100-4 2 2 0 000 4z"></path>
    </svg>`,
    iconGradient: "from-indigo-500 to-blue-500",
    textColor: "text-indigo-400",
    borderColor: "border-indigo-300/30 dark:border-indigo-400/20",
    backgroundGradient: "from-indigo-500/10 via-blue-500/5 to-indigo-600/10",
    services: [
      { href: "/plans/online-store", label: "Online Store Setup" },
      { href: "/plans/online-store", label: "Product Pages That Sell" },
      { href: "/plans/online-store", label: "Dynamic Pricing" },
      { href: "/plans/online-store", label: "AI-Powered Search" },
      { href: "/plans/online-store", label: "Personalized Recommendations" },
      { href: "/plans/online-store", label: "Cart-Recovery Emails" }
    ]
  },

  // Column 3: Automation
  {
    title: "Automation",
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
      <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
      <polyline points="7.5,4.21 12,6.81 16.5,4.21"></polyline>
      <polyline points="7.5,19.79 7.5,14.6 3,12"></polyline>
      <polyline points="21,12 16.5,14.6 16.5,19.79"></polyline>
      <polyline points="3.27,6.96 12,12.01 20.73,6.96"></polyline>
      <line x1="12" y1="22.08" x2="12" y2="12"></line>
    </svg>`,
    iconGradient: "from-green-500 to-emerald-500",
    textColor: "text-green-400",
    borderColor: "border-green-300/30 dark:border-green-400/20",
    backgroundGradient: "from-green-500/10 via-emerald-500/5 to-green-600/10",
    services: [
      { href: "/products/automation-integration", label: "Workflow Automation" },
      { href: "/products/automation-integration", label: "Invoice & Billing" },
      { href: "/products/automation-integration", label: "CRM Automation" },
      { href: "/products/automation-integration", label: "Smart Scheduling" },
      { href: "/products/automation-integration", label: "Inventory Sync" },
      { href: "/products/automation-integration", label: "Email Automation" }
    ],
    hasSecondarySection: true,
    secondaryTitle: "AI Content",
    secondaryIcon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
      <polyline points="14,2 14,8 20,8"></polyline>
      <line x1="16" y1="13" x2="8" y2="13"></line>
      <line x1="16" y1="17" x2="8" y2="17"></line>
    </svg>`,
    secondaryIconGradient: "from-purple-500 to-pink-500",
    secondaryTextColor: "text-purple-400",
    secondaryServices: [
      { href: "/ai-team", label: "AI Product Descriptions" },
      { href: "/ai-team", label: "AI Product Photography" },
      { href: "/ai-team", label: "AI Product Videos" }
    ]
  },

  // Column 4: Photo & Video (+ 360° Experiences)
  {
    title: "Photo & Video",
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
      <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"></path>
      <circle cx="12" cy="13" r="4"></circle>
    </svg>`,
    iconGradient: "from-rose-500 to-pink-500",
    textColor: "text-rose-400",
    borderColor: "border-rose-300/30 dark:border-rose-400/20",
    backgroundGradient: "from-rose-100/70 via-pink-100/40 to-rose-200/60 dark:from-rose-500/10 dark:via-pink-500/5 dark:to-rose-600/10",
    roundedClass: "rounded-tr-lg",
    services: [
      { href: "/services", label: "Product Photography" },
      { href: "/services", label: "Real Estate Photography" },
      { href: "/services", label: "Business Portraits" }
    ],
    hasSecondarySection: true,
    secondaryTitle: "360° Experiences",
    secondaryIcon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
      <circle cx="12" cy="12" r="10"></circle>
      <path d="M8 12h8"></path>
      <path d="M12 8v8"></path>
      <path d="M16.24 7.76l-8.48 8.48"></path>
      <path d="M7.76 7.76l8.48 8.48"></path>
    </svg>`,
    secondaryIconGradient: "from-pink-500 to-rose-500",
    secondaryTextColor: "text-pink-400",
    secondaryServices: [
      { href: "/free-360-photo", label: "360° Virtual Tours" },
      { href: "/free-360-photo", label: "360° Photos & Video" },
      { href: "/free-360-photo", label: "360° eCommerce Tours" }
    ]
  }
];
---

<!-- Service Menus Section -->
<div class="max-w-[1440px] mx-auto px-4 lg:px-6">
  <div class="pt-8 pb-4">
    <h3 class="apple-gradient-text text-2xl font-bold text-gray-800 dark:text-white mb-6 text-left transition-colors duration-300">Our Services</h3>
  </div>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-0">
    {serviceCategories.map((category, index) => {
      let borderClasses = "border-t border-l";

      // Last box: add right border to close the group
      if (index === serviceCategories.length - 1) {
        borderClasses = "border-t border-l border-r";
      }

      return (
        <ServiceCategory {...category} borderClasses={borderClasses} />
      );
    })}
  </div>
</div>
