---
// Blog Article Card Component - Reusable card for blog articles.
// Thumbnail preference: a real banner image → the post's own brand illustration
// (the same SVG shown on the post page) → a colored gradient with the category icon.
import Illustration from '../illustrations/Illustration.astro';
import type { IllKind } from '../../utils/postIllustration';

interface Props {
  icon: 'chat' | 'document' | 'analytics';
  category: string;
  title: string;
  categoryColor: 'blue' | 'purple' | 'orange';
  href: string;
  image?: string;
  illustration?: IllKind;
}

const { icon, category, title, categoryColor, href, image, illustration } = Astro.props;

// Icon mapping (used for the fallback banner)
const iconSvgs = {
  chat: `<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>`,
  document: `<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14,2 14,8 20,8"></polyline>`,
  analytics: `<line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line>`
};

// Color mapping for gradients and styles
const colorMap = {
  blue: {
    gradient: 'from-blue-500/20 to-cyan-500/20',
    iconColor: 'text-blue-400',
    badgeBg: 'bg-blue-500/20',
    badgeText: 'text-blue-400',
    hoverText: 'group-hover:text-blue-600 dark:group-hover:text-blue-400',
    buttonColor: 'text-blue-600 dark:text-blue-400',
    shadowColor: 'rgba(59, 130, 246, 0.1)',
    hoverShadowColor: 'rgba(59, 130, 246, 0.3)'
  },
  purple: {
    gradient: 'from-purple-500/20 to-pink-500/20',
    iconColor: 'text-purple-400',
    badgeBg: 'bg-purple-500/20',
    badgeText: 'text-purple-400',
    hoverText: 'group-hover:text-purple-600 dark:group-hover:text-purple-400',
    buttonColor: 'text-purple-600 dark:text-purple-400',
    shadowColor: 'rgba(139, 92, 246, 0.1)',
    hoverShadowColor: 'rgba(139, 92, 246, 0.3)'
  },
  orange: {
    gradient: 'from-orange-500/20 to-yellow-500/20',
    iconColor: 'text-orange-400',
    badgeBg: 'bg-orange-500/20',
    badgeText: 'text-orange-400',
    hoverText: 'group-hover:text-orange-600 dark:group-hover:text-orange-400',
    buttonColor: 'text-orange-600 dark:text-orange-400',
    shadowColor: 'rgba(249, 115, 22, 0.1)',
    hoverShadowColor: 'rgba(249, 115, 22, 0.3)'
  }
};

const colors = colorMap[categoryColor];
---

<a href={href} class="group flex items-start gap-3 no-underline">
  <!-- Thumbnail — small square, inline with the title. Real image if the post
       has one, otherwise a category-colored tile with the topic icon. -->
  <div class="flex-shrink-0 w-16 h-16 rounded-lg overflow-hidden border border-gray-200/30 dark:border-white/20 transition-all duration-500"
       style={`box-shadow: 0 4px 16px ${colors.shadowColor};`}>
    {image ? (
      <img
        src={image}
        alt={title}
        loading="lazy"
        width="64"
        height="64"
        class="w-full h-full object-cover transition-transform duration-500"
      />
    ) : illustration ? (
      <div class={`w-full h-full flex items-center justify-center bg-gradient-to-br ${colors.gradient} p-1.5`}>
        <Illustration kind={illustration} class="w-full" />
      </div>
    ) : (
      <div class={`relative w-full h-full flex items-center justify-center bg-gradient-to-br ${colors.gradient}`}>
        <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/10 to-transparent -translate-x-full transition-transform duration-1000"></div>
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class={`${colors.iconColor} opacity-80 relative z-10`}>
          <Fragment set:html={iconSvgs[icon]} />
        </svg>
      </div>
    )}
  </div>

  <!-- Content -->
  <div class="min-w-0 flex-1">
    <span class={`inline-block px-2 py-0.5 ${colors.badgeBg} ${colors.badgeText} text-[11px] rounded-md`}>
      {category}
    </span>
    <h5 class={`text-gray-800 dark:text-white/90 text-sm font-medium leading-snug mt-1 ${colors.hoverText} transition-colors duration-300`}>
      {title}
    </h5>
    <span class={`${colors.buttonColor} text-xs font-medium inline-flex items-center gap-1 mt-1`}>
      Read more
      <svg class="w-3 h-3 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    </span>
  </div>
</a>
