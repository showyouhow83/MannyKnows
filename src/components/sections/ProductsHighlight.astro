---
// Products highlight — sits inside the homepage "Our Products" section, beneath the
// Contractor Suite showcase. Surfaces the other apps & services as cards and points
// visitors to the full /products page. Flagship entries are excluded (already shown above).
import { getCollection } from 'astro:content';
import ProductCard from '../products/ProductCard.astro';
import Button from '../ui/Button.astro';

const products = (await getCollection('products'))
  .filter((p) => !p.data.draft && !p.data.flagship)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 6);
---

{products.length > 0 && (
  <div class="max-w-6xl mx-auto mt-16 pt-12 border-t border-light-tertiary dark:border-dark-accent">
    <div class="text-center max-w-2xl mx-auto mb-10">
      <h3 class="sf-bold text-2xl md:text-3xl font-bold text-text-light-primary dark:text-text-dark-primary mb-3">
        More <span class="apple-gradient-text" data-colorful-title>apps &amp; services</span> we offer
      </h3>
      <p class="text-text-light-secondary dark:text-text-dark-secondary leading-relaxed">
        Ready-to-deploy software and done-for-you services — pick what fits, and we tailor it to your business.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {products.map((p) => (
        <ProductCard
          href={`/products/${p.id}`}
          title={p.data.title}
          tagline={p.data.tagline}
          type={p.data.type}
          image={p.data.image}
          services={p.data.services}
        />
      ))}
    </div>

    <div class="text-center mt-10">
      <Button href="/products" text="Browse all products" variant="cta" arrow={true} />
    </div>
  </div>
)}
