---
// Monthly retainer plans. Prices are "starting at" — every plan is adjusted to
// the client, so these are entry points, not fixed SKUs. Cards escalate
// Watch → Improve → Grow → Build; "Optimize" is flagged most popular.
interface Plan {
  name: string;
  icon: string;
  price: string;              // shown as "Starting at $<price>/mo"
  promise: string;
  note?: string;              // small line under the name (e.g. "For a site you already have")
  inherits?: string;          // "Everything in <inherits>, plus:"
  features: string[];
  featured?: boolean;
}

const plans: Plan[] = [
  {
    name: 'Tune-Up',
    icon: '⚙️',
    price: '350',
    promise: 'Keep your site sharp — fast, found, and converting.',
    note: 'For a site you already have — no website build.',
    features: [
      'Monthly Lighthouse, Core Web Vitals & security scan',
      'SEO tuning — technical checks + on-page fixes',
      'Speed & JS add-on opportunities (quick wins done)',
      'AI tuning — your chatbot & automations kept sharp',
      'A set block of fixes each month + a plain-English report',
    ],
  },
  {
    name: 'Optimize',
    icon: '🔧',
    price: '700',
    promise: 'Make it measurably better, every month.',
    inherits: 'Tune-Up',
    features: [
      '1–2 real improvements implemented every month',
      'Speed, SEO, conversion or JS-feature work — shipped',
      'Deeper analytics: where visitors drop, what to fix next',
      'More hands-on hours',
    ],
    featured: true,
  },
  {
    name: 'Growth',
    icon: '📈',
    price: '1,200',
    promise: 'Grow traffic and conversions on purpose.',
    inherits: 'Optimize',
    features: [
      'Active technical SEO + CRO campaigns',
      'A/B tests, landing pages, structured data',
      'Monthly strategy session + rolling roadmap',
      'Priority on new builds & automations',
    ],
  },
  {
    name: 'Fractional Partner',
    icon: '🧩',
    price: '2,000',
    promise: 'Your part-time technical team.',
    inherits: 'Growth',
    features: [
      'Ongoing dev capacity — new features, AI automation',
      'Custom software built to fit as you grow',
      'The full loop: sell → capture leads → capture data → more leads',
      'First in line, deepest involvement',
    ],
  },
];

const cardBase =
  'relative flex flex-col rounded-2xl border bg-white dark:bg-dark-secondary p-6 transition-all duration-300';
---

<div class="max-w-6xl mx-auto">
  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4 items-stretch">
    {plans.map((p) => (
      <div
        class={`${cardBase} ${
          p.featured
            ? 'border-primary-blue/50 shadow-lg shadow-primary-blue/10 ring-1 ring-primary-blue/30 lg:-mt-2 lg:mb-2'
            : 'border-light-tertiary dark:border-dark-accent hover:border-primary-blue/30 hover:shadow-lg'
        }`}
      >
        {p.featured && (
          <span class="absolute -top-3 left-1/2 -translate-x-1/2 whitespace-nowrap bg-gradient-to-r from-primary-blue to-primary-pink text-white text-[11px] font-bold uppercase tracking-wide px-3 py-1 rounded-full shadow">
            Most popular
          </span>
        )}

        <div class="flex items-center gap-2">
          <span class="text-2xl" aria-hidden="true">{p.icon}</span>
          <h3 class="text-lg font-bold text-text-light-primary dark:text-text-dark-primary">{p.name}</h3>
        </div>
        {p.note && (
          <p class="mt-1 text-xs text-text-light-tertiary dark:text-text-dark-tertiary">{p.note}</p>
        )}

        <div class="mt-4">
          <span class="block text-[11px] font-semibold uppercase tracking-wide text-text-light-tertiary dark:text-text-dark-tertiary">Starting at</span>
          <span class="text-4xl font-black text-text-light-primary dark:text-text-dark-primary">${p.price}</span>
          <span class="text-sm text-text-light-secondary dark:text-text-dark-secondary">/mo</span>
        </div>

        <p class="mt-3 text-sm text-text-light-secondary dark:text-text-dark-secondary leading-relaxed">{p.promise}</p>

        <div class="mt-4 pt-4 border-t border-light-tertiary dark:border-dark-accent flex-1">
          {p.inherits && (
            <p class="text-xs font-semibold text-primary-blue dark:text-blue-300 mb-3">Everything in {p.inherits}, plus:</p>
          )}
          <ul class="space-y-2.5">
            {p.features.map((f) => (
              <li class="flex items-start gap-2 text-sm text-text-light-secondary dark:text-text-dark-secondary leading-snug">
                <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-primary-blue dark:text-blue-300" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span>{f}</span>
              </li>
            ))}
          </ul>
        </div>

        <a
          href="/?chat=open&ref=plan"
          class={`mt-6 inline-flex items-center justify-center rounded-xl px-4 py-2.5 text-sm font-semibold transition-all duration-300 ${
            p.featured
              ? 'bg-gradient-to-r from-primary-blue to-primary-pink text-white hover:shadow-[0_10px_30px_rgba(16,209,255,0.3)]'
              : 'border border-primary-blue/40 text-primary-blue dark:text-blue-300 hover:bg-primary-blue/5'
          }`}
        >
          Start with {p.name}
        </a>
      </div>
    ))}
  </div>

  <p class="mt-10 text-center text-sm text-text-light-secondary dark:text-text-dark-secondary max-w-2xl mx-auto">
    Every plan is tailored — I adjust scope and price to what your business actually needs, so the numbers above are a starting point, not a ceiling.
    <a href="/?chat=open&ref=plan" class="text-primary-blue dark:text-blue-300 font-medium hover:underline">Let's build your plan →</a>
  </p>
</div>
