---
// Plan cards — driven by src/data/plans.ts (shared with the /plans/<slug>
// detail pages). Prices are "Starting at"; every plan is tailored per client.
// The Monthly/Yearly toggle swaps between the month-to-month rate and the
// prepaid annual rate (pay the year upfront — 10x monthly — and get 2 months free).
import { websitePlans, yearlyTotal, yearlyMonthly } from '../../data/plans';

const cardBase =
  'relative flex flex-col rounded-2xl border bg-white dark:bg-dark-secondary p-6 transition-all duration-300';
---

<div class="max-w-6xl mx-auto" id="pricingPlans">
  <!-- Billing toggle -->
  <div class="flex flex-col items-center gap-2 mb-10">
    <div class="inline-flex items-center rounded-full border border-light-tertiary dark:border-dark-accent bg-white dark:bg-dark-secondary p-1" role="group" aria-label="Billing period">
      <button type="button" data-billing-btn="monthly" aria-pressed="true" class="billing-btn rounded-full px-5 py-2 text-sm font-semibold transition-all duration-200 bg-gradient-to-r from-primary-blue to-primary-pink text-white shadow">
        Monthly
      </button>
      <button type="button" data-billing-btn="yearly" aria-pressed="false" class="billing-btn rounded-full px-5 py-2 text-sm font-semibold transition-all duration-200 text-text-light-secondary dark:text-text-dark-secondary">
        Yearly <span class="font-bold text-primary-blue dark:text-blue-300 billing-btn-note">· 2 months free</span>
      </button>
    </div>
    <p class="text-xs text-text-light-tertiary dark:text-text-dark-tertiary" data-billing-caption>
      Month-to-month · cancel anytime
    </p>
  </div>

  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4 items-stretch">
    {websitePlans.map((p) => (
      <div
        class={`${cardBase} ${
          p.featured
            ? 'border-primary-blue/50 shadow-lg shadow-primary-blue/10 ring-1 ring-primary-blue/30 lg:-mt-2 lg:mb-2'
            : 'border-light-tertiary dark:border-dark-accent hover:border-primary-blue/30 hover:shadow-lg'
        }`}
      >
        {p.featured && (
          <span class="absolute -top-3 left-1/2 -translate-x-1/2 whitespace-nowrap bg-gradient-to-r from-primary-blue to-primary-pink text-white text-[11px] font-bold uppercase tracking-wide px-3 py-1 rounded-full shadow">
            Most popular
          </span>
        )}

        <div class="flex items-center justify-center gap-2">
          <svg class="w-5 h-5 flex-shrink-0 text-primary-blue dark:text-blue-300" fill="none" stroke="currentColor" stroke-width="1.7" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d={p.icon} /></svg>
          <h3 class="text-base sm:text-lg font-bold text-text-light-primary dark:text-text-dark-primary leading-tight">{p.name}</h3>
        </div>

        <div class="mt-4 text-center">
          <span class="block text-[11px] font-semibold uppercase tracking-wide text-text-light-tertiary dark:text-text-dark-tertiary">Starting at</span>
          <div data-billing-view="monthly" class="whitespace-nowrap leading-none mt-0.5">
            <span class="text-3xl font-black text-text-light-primary dark:text-text-dark-primary">${p.price.toLocaleString('en-US')}</span><span class="text-sm text-text-light-secondary dark:text-text-dark-secondary">/mo</span>
          </div>
          <div data-billing-view="yearly" hidden class="whitespace-nowrap leading-none mt-0.5">
            <span class="text-3xl font-black text-text-light-primary dark:text-text-dark-primary">${yearlyMonthly(p).toLocaleString('en-US')}</span><span class="text-sm text-text-light-secondary dark:text-text-dark-secondary">/mo</span>
          </div>
          <div data-billing-view="monthly" class="text-xs text-text-light-tertiary dark:text-text-dark-tertiary mt-1.5">
            or ${yearlyTotal(p).toLocaleString('en-US')}/yr paid upfront — <span class="text-primary-blue dark:text-blue-300 font-semibold">2 months free</span>
          </div>
          <div data-billing-view="yearly" hidden class="text-xs text-text-light-tertiary dark:text-text-dark-tertiary mt-1.5">
            billed as one payment of ${yearlyTotal(p).toLocaleString('en-US')}/yr · <span class="text-primary-blue dark:text-blue-300 font-semibold">2 months free</span>
          </div>
        </div>

        <p class="mt-3 text-sm text-text-light-secondary dark:text-text-dark-secondary leading-relaxed">{p.tagline}</p>

        <div class="mt-4 pt-4 border-t border-light-tertiary dark:border-dark-accent flex-1">
          {p.builtOn && (
            <p class="mb-2.5 text-xs font-bold text-primary-blue dark:text-blue-300">{p.builtOn}</p>
          )}
          <ul class="space-y-2.5">
            {p.highlights.map((f) => (
              <li class="flex items-start gap-2 text-sm text-text-light-secondary dark:text-text-dark-secondary leading-snug">
                <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-primary-blue dark:text-blue-300" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span>{f}</span>
              </li>
            ))}
          </ul>
        </div>

        <a
          href={`/plans/${p.slug}`}
          class={`mt-4 inline-flex items-center justify-center gap-1 rounded-xl px-4 py-2.5 text-sm font-semibold transition-all duration-300 ${
            p.featured
              ? 'bg-gradient-to-r from-primary-blue to-primary-pink text-white'
              : 'border border-primary-blue/40 text-primary-blue dark:text-blue-300 hover:bg-primary-blue/5'
          }`}
        >
          See everything included
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
        </a>

        <a
          href="#contact"
          data-contact-context={`${p.name} plan`}
          class="mt-3 inline-flex items-center justify-center text-sm font-medium text-primary-blue dark:text-blue-300 hover:underline"
        >
          Get started
        </a>
      </div>
    ))}
  </div>

  <!-- At-a-glance comparison — what's additive as you climb the tiers -->
  <div class="mt-14 max-w-6xl mx-auto">
    <h3 class="text-center text-sm font-bold uppercase tracking-wide text-text-light-tertiary dark:text-text-dark-tertiary mb-5">Compare at a glance</h3>
    <div class="overflow-x-auto rounded-2xl border border-light-tertiary dark:border-dark-accent bg-white dark:bg-dark-secondary">
      <table class="w-full text-sm min-w-[760px] table-fixed">
        <thead>
          <tr class="text-text-light-primary dark:text-text-dark-primary">
            <th class="w-2/5 sticky left-0 z-20 text-left font-semibold px-4 py-3 bg-light-secondary dark:bg-dark-primary border-r border-light-tertiary dark:border-dark-accent">What you get</th>
            <th class="px-3 py-3 font-semibold text-center bg-light-secondary dark:bg-dark-primary">Website I</th>
            <th class="px-3 py-3 font-semibold text-center bg-light-secondary dark:bg-dark-primary">Website II</th>
            <th class="px-3 py-3 font-semibold text-center bg-light-secondary dark:bg-dark-primary">Website III</th>
            <th class="px-3 py-3 font-semibold text-center bg-light-secondary dark:bg-dark-primary">eCommerce</th>
          </tr>
        </thead>
        <tbody class="text-text-light-secondary dark:text-text-dark-secondary">
          {[
            ['Runs on your Brand Brain (private AI)', true, true, true, true],
            ['Remi answers customers 24/7, any language', true, true, true, true],
            ['Found on Google & Maps for local searches', true, true, true, true],
            ['Self-optimizing website (speed, SEO, content)', 'Basic', 'More', 'Full', 'Full'],
            ['Full multi-page, multilingual site', false, true, true, true],
            ['Remi books jobs & captures leads', false, true, true, true],
            ['Remi sells & steers shoppers to products', false, false, true, true],
            ['Full online store (Shopify)', false, false, false, true],
          ].map((row) => (
            <tr class="border-t border-light-tertiary dark:border-dark-accent">
              <td class="sticky left-0 z-10 text-left px-4 py-2.5 bg-white dark:bg-dark-secondary border-r border-light-tertiary dark:border-dark-accent">{row[0]}</td>
              {row.slice(1).map((cell) => (
                <td class="text-center px-3 py-2.5">
                  {typeof cell === 'string' ? (
                    <span class="text-xs font-semibold text-primary-blue dark:text-blue-300">{cell}</span>
                  ) : cell ? (
                    <svg class="w-4 h-4 inline text-green-500" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-label="included"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  ) : (
                    <span class="text-text-light-tertiary/50 dark:text-text-dark-tertiary/50" aria-label="not included">—</span>
                  )}
                </td>
              ))}
            </tr>
          ))}
          <tr class="border-t border-light-tertiary dark:border-dark-accent font-semibold text-text-light-primary dark:text-text-dark-primary">
            <td class="sticky left-0 z-10 text-left px-4 py-2.5 bg-white dark:bg-dark-secondary border-r border-light-tertiary dark:border-dark-accent">Starting at (per month)</td>
            <td class="text-center px-3 py-2.5">$99</td>
            <td class="text-center px-3 py-2.5">$199</td>
            <td class="text-center px-3 py-2.5">$349</td>
            <td class="text-center px-3 py-2.5">$399</td>
          </tr>
        </tbody>
      </table>
    </div>
    <p class="mt-3 text-center text-xs text-text-light-tertiary dark:text-text-dark-tertiary">Each tier includes everything in the one before it — start where you are and move up as you grow.</p>
    <p class="mt-2 text-center text-xs text-text-light-tertiary dark:text-text-dark-tertiary"><a href="/ai-team" class="font-semibold text-primary-blue dark:text-blue-300 hover:underline">Remi</a> is your site's built-in AI agent — chat, sales &amp; booking.</p>
  </div>

  <!-- What the monthly price covers — shown once for all plans -->
  <div class="mt-10 max-w-3xl mx-auto pt-6 border-t border-gray-500/[0.27]">
    <p class="text-center text-sm text-text-light-secondary dark:text-text-dark-secondary leading-relaxed">
      <span class="font-semibold text-text-light-primary dark:text-text-dark-primary">Every plan is fast, secure, and scoped to your business.</span> Your site runs on Cloudflare's global edge network — served from 330+ cities with automatic SSL, DDoS protection, and caching — plus a domain we'll register for you if you don't have one, unlimited traffic, and no metered overages or surprise bills. Graphic design and unlimited stock photos &amp; video are included (via our Envato Elements license — used as-is or reworked with AI into content that's uniquely yours). The prices above are starting points: we tailor the scope and the cost to what your business actually needs, so you only pay for what moves the needle. <a href="#contact" class="text-primary-blue dark:text-blue-300 font-medium hover:underline">Build your plan →</a>
    </p>
    <p class="mt-3 text-center text-xs text-text-light-tertiary dark:text-text-dark-tertiary leading-relaxed">
      Yearly pricing is one upfront payment for 12 months of service — pay for 10 months, get 12 (2 months free). Details in our <a href="/terms" class="underline hover:text-primary-blue">terms</a>.
    </p>
  </div>
</div>

<script>
  // Monthly ⇄ Yearly toggle: swaps cards between the month-to-month rate and
  // the prepaid annual total (both views pre-rendered; JS toggles visibility).
  (function () {
    const root = document.getElementById('pricingPlans');
    if (!root) return;
    const buttons = root.querySelectorAll<HTMLButtonElement>('[data-billing-btn]');
    const caption = root.querySelector('[data-billing-caption]');
    const activeCls = ['bg-gradient-to-r', 'from-primary-blue', 'to-primary-pink', 'text-white', 'shadow'];
    const inactiveCls = ['text-text-light-secondary', 'dark:text-text-dark-secondary'];

    function setBilling(mode: 'monthly' | 'yearly') {
      root.querySelectorAll<HTMLElement>('[data-billing-view]').forEach((el) => {
        el.hidden = el.dataset.billingView !== mode;
      });
      if (caption) {
        caption.textContent = mode === 'monthly'
          ? 'Month-to-month · cancel anytime'
          : 'One upfront payment for the year — 2 months free';
      }
      buttons.forEach((b) => {
        const active = b.dataset.billingBtn === mode;
        b.setAttribute('aria-pressed', String(active));
        activeCls.forEach((c) => b.classList.toggle(c, active));
        inactiveCls.forEach((c) => b.classList.toggle(c, !active));
        const note = b.querySelector('.billing-btn-note');
        if (note) note.classList.toggle('text-white', active);
      });
    }

    buttons.forEach((b) =>
      b.addEventListener('click', () => setBilling(b.dataset.billingBtn as 'monthly' | 'yearly'))
    );
  })();
</script>
