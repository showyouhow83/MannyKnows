---
// Idea Launchpad — "bring an idea, we design, build, and launch the app for you."
// Sits inside a homepage PageSection (badge/title/subtitle come from index.astro).
import Button from '../ui/Button.astro';
import StepCards from '../ui/StepCards.astro';

// Each step carries an inline Heroicon path so the flow reads visually, not as
// a wall of numbered text.
const steps = [
  {
    n: '01',
    title: 'Tell us your idea',
    body: "A sentence or two is plenty — send a message or text (917) 475-6634. No pitch deck, no tech jargon needed.",
    icon: 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.9 9.9 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z',
  },
  {
    n: '02',
    title: 'We map it out',
    body: "We turn it into a clear plan — what it does, who it's for, how it works — and show you before we build a thing.",
    icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4',
  },
  {
    n: '03',
    title: 'We build it',
    body: "We design and develop the real thing — a working prototype in hours, the full app close behind.",
    icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
  },
  {
    n: '04',
    title: 'We launch & grow it',
    body: "We put it live, get it in front of real people, and keep improving it as it grows.",
    icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6',
  },
];
---

<div class="max-w-6xl mx-auto">
  <!-- Steps -->
  <StepCards steps={steps} class="" />

  <!-- Offer + CTA -->
  <div class="mt-10 max-w-2xl mx-auto text-center">
    <p class="text-text-light-secondary dark:text-text-dark-secondary leading-relaxed mb-6">
      <strong class="text-text-light-primary dark:text-text-dark-primary">No upfront cost to get started.</strong>
      You bring the idea; we design, build, launch, and market it — and turn it into a real, working app. We only take on a handful at a time, so tell us about yours.
    </p>
    <Button href="#contact" text="Tell us your idea" variant="cta" arrow={true} />
  </div>
</div>
