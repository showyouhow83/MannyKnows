---
// Idea Launchpad — the "bring an idea, I'll build & market it" partnership offer.
// Sits inside a homepage PageSection (which supplies the badge/title/subtitle).
import Button from '../ui/Button.astro';

const steps = [
  {
    n: '01',
    title: 'Pitch it',
    body: "Tell me your idea — a few sentences is plenty. Use the chat or drop me a note.",
  },
  {
    n: '02',
    title: 'We pressure-test it',
    body: "Together we look at whether there's a real audience, whether it's buildable, and what it would take.",
  },
  {
    n: '03',
    title: 'I build it',
    body: "If we both see potential, I design and develop it — fast, with AI-assisted development.",
  },
  {
    n: '04',
    title: 'We launch & grow it',
    body: "I handle the launch and the marketing too, and we grow it from there.",
  },
];
---

<div class="max-w-6xl mx-auto">
  <!-- Steps -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
    {steps.map((s) => (
      <div class="relative flex flex-col bg-white dark:bg-dark-secondary border border-light-tertiary dark:border-dark-accent rounded-xl p-6 transition-all duration-300 hover:shadow-lg hover:border-primary-blue/30">
        <span class="text-3xl font-black apple-gradient-text mb-3">{s.n}</span>
        <h3 class="text-lg font-bold text-text-light-primary dark:text-text-dark-primary mb-2">{s.title}</h3>
        <p class="text-sm text-text-light-secondary dark:text-text-dark-secondary leading-relaxed">{s.body}</p>
      </div>
    ))}
  </div>

  <!-- Honest terms + CTA -->
  <div class="mt-10 max-w-3xl mx-auto text-center">
    <p class="text-text-light-secondary dark:text-text-dark-secondary leading-relaxed mb-6">
      <strong class="text-text-light-primary dark:text-text-dark-primary">No upfront cost — I build it as your technical co-founder.</strong>
      You bring the idea and the vision; I bring the design, development, and marketing. We co-own
      what we launch and agree on a fair equity split up front. I only take on a few at a time, so
      I'm picky about the ones I can genuinely help get off the ground.
    </p>
    <Button href="/?chat=open&ref=idea" text="Pitch your idea" variant="cta" arrow={true} />
  </div>
</div>
