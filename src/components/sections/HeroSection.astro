---
export interface Props {
  title: string;
  highlightedText: string;
  /** Text rendered after the highlighted span (e.g. ", less busywork — for Western Mass contractors."). */
  titleAfter?: string;
  subtitle: string;
  /** Optional small pill shown above the headline (e.g. a location / niche tag). */
  badge?: string;
  className?: string;
}

const { title, highlightedText, titleAfter = "", subtitle, badge, className = "" } = Astro.props;
---

<section id="hero" class={`relative overflow-hidden pt-12 pb-6 md:pt-16 md:pb-8 text-center apple-gradient-container ${className}`}>
  <!-- Decorative astronaut mascot — appears once /art/astronaut-rocket.png is added to public/art/. -->
  <div class="astronaut-mascot hidden lg:block" aria-hidden="true"></div>
  <div class="relative z-10 max-w-[1440px] mx-auto px-2">
    <div class="max-w-16xl mx-auto">
      {badge && (
        <span class="inline-flex items-center gap-2 mb-5 px-4 py-1.5 rounded-full border border-gray-200/40 dark:border-white/15 bg-white/50 dark:bg-white/5 backdrop-blur-md text-sm sf-medium text-text-light-secondary dark:text-text-dark-secondary">
          {badge}
        </span>
      )}
      <h1 class="sf-bold text-4xl md:text-6xl lg:text-7xl mb-6 apple-headline" style="font-size: clamp(2.5rem, 5vw, 4.5rem);">
        {title} <span class="apple-gradient-text" data-colorful-title>{highlightedText}</span>{titleAfter}
      </h1>
      <p class="sf-regular text-xl mb-0 text-text-light-secondary dark:text-text-dark-secondary apple-body-text max-w-3xl mx-auto">
        {subtitle}
      </p>
    </div>
  </div>
</section>

<style>
  /* Decorative astronaut mascot (hero accent). CSS background-image so a missing
     file degrades to nothing (no broken-image icon) until the PNG is added. */
  .astronaut-mascot {
    position: absolute;
    bottom: 0.25rem;
    left: max(0.5rem, 1.5vw);
    width: clamp(150px, 15vw, 230px);
    aspect-ratio: 1 / 1;
    background: url('/art/astronaut-rocket.png') center / contain no-repeat;
    pointer-events: none;
    z-index: 0;
    opacity: 0.95;
    filter: drop-shadow(0 14px 26px rgba(0, 0, 0, 0.14));
    animation: astronautFloat 6s ease-in-out infinite;
    will-change: transform;
  }
  @keyframes astronautFloat {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50%      { transform: translateY(-12px) rotate(3deg); }
  }
  @media (prefers-reduced-motion: reduce) {
    .astronaut-mascot { animation: none; }
  }

  /* Hero responsive styles */
  @media (max-width: 768px) {
    .hero {
      @apply py-10 pb-16 min-h-[calc(100vh-120px)];
    }
    
    .hero h1 {
      @apply text-4xl;
    }
    
    .hero p {
      @apply text-lg;
    }
    
    .hero .flex {
      @apply flex-col items-center;
    }
    
    .btn-primary,
    .btn-secondary {
      @apply w-full max-w-xs;
    }
  }
</style>
