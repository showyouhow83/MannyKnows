---
// Homepage AI Team teaser — shows the roster avatars and routes to the
// /ai-team lander. Data from src/data/aiTeam.ts.
import { team, aiTeamStartingPrice, aiTeamSetupFee } from '../../data/aiTeam';
import AgentAvatar from '../team/AgentAvatar.astro';
import Button from '../ui/Button.astro';

const roster = [...team].sort((a, b) => a.order - b.order);
const startFrom = aiTeamStartingPrice.toLocaleString('en-US');
const setup = aiTeamSetupFee.toLocaleString('en-US');
---

<div class="max-w-5xl mx-auto">
  <a href="/ai-team" class="block group" aria-label="Meet the AI Team">
    <div class="grid grid-cols-4 sm:grid-cols-7 gap-3 sm:gap-4 max-w-3xl mx-auto">
      {roster.map((a) => (
        <div class="flex flex-col items-center gap-1.5">
          <div class="w-full aspect-square rounded-2xl bg-gradient-to-br from-primary-blue/[0.07] via-transparent to-primary-pink/[0.07] transition-transform group-hover:-translate-y-0.5">
            <AgentAvatar agent={a.id} class="w-full h-full" />
          </div>
          <span class="text-[11px] sm:text-xs font-bold text-text-light-primary dark:text-text-dark-primary">{a.name}</span>
          <span class="hidden sm:block text-[10px] text-text-light-tertiary dark:text-text-dark-tertiary text-center leading-tight">{a.role}</span>
        </div>
      ))}
    </div>
  </a>

  <div class="text-center max-w-2xl mx-auto mt-10">
    <p class="text-text-light-secondary dark:text-text-dark-secondary leading-relaxed mb-6">
      Sales &amp; booking, research, copywriting, graphics &amp; video, voice, publishing, and reviews — <strong class="text-text-light-primary dark:text-text-dark-primary">built around your business and yours to run on demand</strong>. Hire one like staff, or the whole team. From ${startFrom}/mo per agent, plus a one-time ${setup} setup.
    </p>
    <Button href="/ai-team" text="Meet &amp; hire the AI Team" variant="cta" arrow={true} />
  </div>
</div>
