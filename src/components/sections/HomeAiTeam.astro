---
// Homepage AI Team teaser — shows the roster avatars and routes to the
// /ai-team lander. Data from src/data/aiTeam.ts.
import { team, aiTeamStartingPrice, aiTeamSetupFee } from '../../data/aiTeam';
import AgentAvatar from '../team/AgentAvatar.astro';
import Button from '../ui/Button.astro';

const roster = [...team].sort((a, b) => a.order - b.order);
const startFrom = aiTeamStartingPrice.toLocaleString('en-US');
const setup = aiTeamSetupFee.toLocaleString('en-US');

// Compact specialty labels for the teaser grid (the full role is on /ai-team).
const specialty: Record<string, string> = {
  manny: 'Manager',
  desi: 'Front desk',
  eve: 'Research',
  elly: 'Copywriting',
  eny: 'Graphics & video',
  mimi: 'Voice',
  essie: 'SEO',
  bap: 'Publishing',
  addy: 'Paid ads',
  upie: 'Engagement',
  ana: 'Analytics',
};
---

<div class="max-w-5xl mx-auto">
  <a href="/ai-team" class="block group" aria-label="Meet the AI Team">
    <div class="grid grid-cols-3 sm:grid-cols-6 gap-3 sm:gap-4 lg:gap-8 max-w-3xl lg:max-w-5xl mx-auto">
      {roster.map((a) => (
        <div class="flex flex-col items-center gap-1">
          <div class="w-full aspect-square rounded-2xl bg-gradient-to-br from-primary-blue/[0.07] via-transparent to-primary-pink/[0.07]">
            <AgentAvatar agent={a.id} class="w-full h-full" />
          </div>
          <span class="text-[11px] sm:text-xs font-bold text-text-light-primary dark:text-text-dark-primary leading-tight">{a.name}</span>
          <span class="text-[9px] sm:text-[10px] text-text-light-tertiary dark:text-text-dark-tertiary text-center leading-tight">{specialty[a.id] ?? a.role}</span>
        </div>
      ))}
    </div>
  </a>

  <div class="text-center max-w-2xl mx-auto mt-10">
    <p class="text-text-light-secondary dark:text-text-dark-secondary leading-relaxed mb-6">
      Front desk, research, copywriting, graphics &amp; video, voice, SEO, publishing, paid ads, engagement, and reporting — <strong class="text-text-light-primary dark:text-text-dark-primary">ten specialists, one shared brain, and Manny managing the handoffs</strong>. Hire one like staff, or the whole team. From ${startFrom}/mo per agent, plus a one-time ${setup} setup.
    </p>
    <Button href="/ai-team" text="Meet & hire the AI Team" variant="cta" arrow={true} />
  </div>
</div>
