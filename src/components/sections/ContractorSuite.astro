---
// ContractorSuite.astro
// Flagship product showcase for the Products section: an all-in-one platform
// for contractors. Their website generates leads, the admin works those leads
// through the pipeline, and the owner runs crews, scheduling, and client
// updates from one place. SL Painting is the live flagship build.
//
// Renders inner content only (no <section>) — it lives inside the existing
// <PageSection id="products"> in index.astro.
import Button from '../ui/Button.astro';

// The four pillars of the suite
const pillars = [
  {
    title: 'Lead-Gen Website',
    desc: 'A fast, branded site built to turn visitors into booked estimates — quote forms, chat, and follow-up baked in.',
    gradient: 'from-blue-500 to-cyan-500',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>`
  },
  {
    title: 'Lead Pipeline',
    desc: 'Every lead in one dashboard, moving from new inquiry to estimate to won — so nothing slips through the cracks.',
    gradient: 'from-indigo-500 to-purple-500',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="18" rx="1"></rect><rect x="14" y="3" width="7" height="11" rx="1"></rect></svg>`
  },
  {
    title: 'Crews & Scheduling',
    desc: 'Assign jobs, schedule crews, and keep the whole team on the same calendar — from any device, in the field or the office.',
    gradient: 'from-green-500 to-emerald-500',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>`
  },
  {
    title: 'Photos & Updates',
    desc: 'Capture before/after photos and send clients progress updates in a tap — the kind of proof that earns referrals.',
    gradient: 'from-pink-500 to-rose-500',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><path d="M21 15l-5-5L5 21"></path></svg>`
  }
];

// Highlights shown next to the flagship showcase
const flagshipPoints = [
  'Leads captured straight from the website',
  'Jobs tracked from quote to final walkthrough',
  'One crew schedule the whole team can see',
  'Before/after galleries clients love'
];
---

<div class="max-w-6xl mx-auto -mt-8">
  <!-- Product identity -->
  <div class="text-center max-w-2xl mx-auto mb-12">
    <span class="inline-block bg-gradient-to-r from-primary-blue/10 via-purple-500/10 to-primary-pink/10 text-primary-blue px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider mb-4">
      Contractor Suite
    </span>
    <h3 class="sf-bold text-2xl md:text-4xl font-bold text-text-light-primary dark:text-text-dark-primary mb-4">
      Everything a contractor needs to <span class="apple-gradient-text" data-colorful-title>run the whole job</span>
    </h3>
    <p class="text-lg text-text-light-secondary dark:text-text-dark-secondary leading-relaxed">
      One platform from the first lead to the final walkthrough — your website brings the work in,
      and the admin keeps crews, schedules, and clients moving in sync.
    </p>
  </div>

  <!-- The four pillars -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-14">
    {pillars.map((pillar) => (
      <div class="bg-white dark:bg-dark-secondary border border-light-tertiary dark:border-dark-accent rounded-xl p-6 hover:shadow-lg transition-all duration-300">
        <div class={`w-12 h-12 rounded-xl bg-gradient-to-br ${pillar.gradient} flex items-center justify-center text-white mb-4`}>
          <Fragment set:html={pillar.icon} />
        </div>
        <h4 class="text-lg font-bold text-text-light-primary dark:text-text-dark-primary mb-2">
          {pillar.title}
        </h4>
        <p class="text-sm text-text-light-secondary dark:text-text-dark-secondary leading-relaxed">
          {pillar.desc}
        </p>
      </div>
    ))}
  </div>

  <!-- Flagship showcase: SL Painting -->
  <div class="rounded-2xl border border-light-tertiary dark:border-dark-accent bg-gradient-to-br from-white via-gray-50 to-gray-100 dark:from-dark-secondary dark:via-dark-secondary dark:to-dark-primary p-8 md:p-10">
    <div class="flex flex-col lg:flex-row items-center gap-10">
      <!-- Story -->
      <div class="flex-1 w-full">
        <span class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-wider text-primary-blue mb-3">
          <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
          Flagship build · Live now
        </span>
        <h3 class="sf-bold text-2xl md:text-3xl font-bold text-text-light-primary dark:text-text-dark-primary mb-3">
          SL Painting
        </h3>
        <p class="text-text-light-secondary dark:text-text-dark-secondary leading-relaxed mb-6">
          A painting contractor running its entire operation on the suite. The website brings in
          leads, the admin works them through every stage, and the crew runs the day — all from one place.
        </p>
        <ul class="space-y-3 mb-8">
          {flagshipPoints.map((point) => (
            <li class="flex items-start gap-3 text-text-light-primary dark:text-text-dark-primary">
              <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              <span>{point}</span>
            </li>
          ))}
        </ul>
        <div class="flex flex-col sm:flex-row gap-4">
          <Button
            href="/?chat=open&ref=contractor-suite"
            text="Get this for your business"
            variant="cta"
            arrow={true}
          />
        </div>
        <p class="text-sm text-text-light-tertiary dark:text-text-dark-tertiary mt-5">
          Built for painters, roofers, landscapers, remodelers &amp; other field-service crews.
        </p>
      </div>

      <!-- Lead-pipeline mockup -->
      <div class="flex-1 w-full">
        <div class="rounded-2xl bg-white dark:bg-dark-primary border border-light-tertiary dark:border-dark-accent shadow-xl p-4">
          <div class="flex items-center justify-between px-1 mb-3">
            <span class="text-xs font-bold uppercase tracking-wider text-text-light-tertiary dark:text-text-dark-tertiary">
              Lead Pipeline
            </span>
            <span class="flex gap-1.5">
              <span class="w-2.5 h-2.5 rounded-full bg-red-400"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-yellow-400"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-green-400"></span>
            </span>
          </div>
          <div class="grid grid-cols-3 gap-2">
            <!-- Column: New -->
            <div class="rounded-lg bg-gray-50 dark:bg-dark-secondary p-2">
              <p class="text-[10px] font-bold uppercase tracking-wide text-text-light-tertiary dark:text-text-dark-tertiary mb-2 px-1">New</p>
              <div class="rounded-md bg-white dark:bg-dark-primary border border-light-tertiary dark:border-dark-accent p-2 mb-2">
                <p class="text-[11px] font-semibold text-text-light-primary dark:text-text-dark-primary leading-tight">Kitchen repaint</p>
                <span class="inline-block mt-1 h-1.5 w-10 rounded-full bg-blue-400"></span>
              </div>
              <div class="rounded-md bg-white dark:bg-dark-primary border border-light-tertiary dark:border-dark-accent p-2">
                <p class="text-[11px] font-semibold text-text-light-primary dark:text-text-dark-primary leading-tight">Exterior trim</p>
                <span class="inline-block mt-1 h-1.5 w-8 rounded-full bg-blue-400"></span>
              </div>
            </div>
            <!-- Column: Scheduled -->
            <div class="rounded-lg bg-gray-50 dark:bg-dark-secondary p-2">
              <p class="text-[10px] font-bold uppercase tracking-wide text-text-light-tertiary dark:text-text-dark-tertiary mb-2 px-1">Scheduled</p>
              <div class="rounded-md bg-white dark:bg-dark-primary border border-light-tertiary dark:border-dark-accent p-2">
                <p class="text-[11px] font-semibold text-text-light-primary dark:text-text-dark-primary leading-tight">2-story exterior</p>
                <span class="inline-block mt-1 h-1.5 w-12 rounded-full bg-yellow-400"></span>
              </div>
            </div>
            <!-- Column: Won -->
            <div class="rounded-lg bg-gray-50 dark:bg-dark-secondary p-2">
              <p class="text-[10px] font-bold uppercase tracking-wide text-text-light-tertiary dark:text-text-dark-tertiary mb-2 px-1">Won</p>
              <div class="rounded-md bg-white dark:bg-dark-primary border border-light-tertiary dark:border-dark-accent p-2">
                <p class="text-[11px] font-semibold text-text-light-primary dark:text-text-dark-primary leading-tight">Office lobby</p>
                <span class="inline-block mt-1 h-1.5 w-9 rounded-full bg-green-400"></span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
