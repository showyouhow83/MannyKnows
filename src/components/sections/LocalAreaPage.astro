---
// Shared template for the per-town local-SEO landing pages. Driven entirely by
// a LocalArea record (src/data/localAreas.ts) so every town page stays honest
// and distinct while sharing one layout. Thin page wrappers live at
// src/pages/web-design-<slug>-ma.astro.
import BaseLayout from '../../layouts/BaseLayout.astro';
import NavBar from '../navigation/NavBar.astro';
import DockMenu from '../navigation/DockMenu.astro';
import Section from '../layout/Section.astro';
import Container from '../layout/Container.astro';
import QuoteBlock from '../ui/QuoteBlock.astro';
import Faq from '../ui/Faq.astro';
import { getTestimonial } from '../../data/testimonials';
import { offers, servedTowns, type LocalArea } from '../../data/localAreas';

interface Props {
  area: LocalArea;
}
const { area } = Astro.props;

const faqs = [
  {
    q: `How much does a website cost in ${area.name}, MA?`,
    a: 'Our Smart Website (AI) plan starts at $350/mo with no big upfront bill — a multilingual site, an AI agent that answers customers and books appointments, Google Business Profile setup, technical SEO, and ongoing maintenance included. One-time builds are also available; every plan is scoped to your business.',
  },
  {
    q: `Do you work with businesses outside ${area.name}?`,
    a: 'Yes — we work across all of Western Massachusetts (Springfield, Chicopee, Holyoke, Northampton, Westfield, Agawam, Amherst, and beyond), and remotely with businesses anywhere.',
  },
  {
    q: 'Can you fix or improve the website I already have?',
    a: "Absolutely. We audit what you have, fix what's slowing it down — speed, technical SEO, mobile issues, conversion problems — and then keep it maintained. You don't have to start over to get a site that performs.",
  },
  {
    q: 'What makes MannyKnows different from a big agency or a DIY builder?',
    a: "Twenty years of engineering for enterprise and startups — including eCommerce at Bob's Discount Furniture and consulting at Accenture — applied to local businesses, at local-business prices. You get senior-level work and a direct line to the people doing it, not an account manager.",
  },
];

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'MannyKnows',
  description: `Web design, technical SEO, and custom software for businesses in ${area.name} and Western Massachusetts.`,
  url: `https://mannyknows.com/web-design-${area.slug}-ma`,
  email: 'mm@mannyknows.com',
  telephone: '+1-413-361-8451',
  address: { '@type': 'PostalAddress', addressLocality: area.name, addressRegion: 'MA', addressCountry: 'US' },
  areaServed: servedTowns.map((t) => ({ '@type': 'City', name: `${t.name}, MA` })),
};

const quote = getTestimonial(area.proofBusiness);
const contactContext = `Web design ${area.name}`;
---

<BaseLayout title={area.metaTitle} description={area.metaDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  <main class="relative bg-light-primary dark:bg-dark-primary text-text-light-primary dark:text-text-dark-primary min-h-screen transition-colors duration-300">

    <header class="relative bg-gradient-to-t from-gray-50/50 via-gray-100/30 to-gray-50/20 dark:from-gray-900/60 dark:via-slate-800/40 dark:to-gray-900/30 transition-colors duration-300">
      <NavBar />
      <nav aria-label="breadcrumb" class="max-w-[1440px] mx-auto px-4 lg:px-6 pt-6 pb-4">
        <ol class="flex flex-wrap items-center gap-2 text-sm text-text-light-secondary dark:text-text-dark-secondary">
          <li><a href="/" class="hover:text-primary-blue transition-colors">Home</a></li>
          <li class="flex items-center"><span class="mx-2 text-text-light-tertiary dark:text-text-dark-tertiary">/</span><span class="text-text-light-primary dark:text-text-dark-primary font-medium">Web Design {area.name}, MA</span></li>
        </ol>
      </nav>
      <div class="pb-12 px-4">
        <div class="max-w-3xl mx-auto text-center">
          <span class="inline-block bg-gradient-to-r from-primary-blue/10 via-purple-500/10 to-primary-pink/10 text-primary-blue px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider mb-4">{area.badge}</span>
          <h1 class="sf-bold apple-headline text-4xl md:text-5xl lg:text-6xl mb-6">
            <span class="apple-gradient-text" data-colorful-title>Web design in {area.name}, MA</span>
          </h1>
          <p class="text-base sm:text-xl text-text-light-secondary dark:text-text-dark-secondary leading-relaxed">
            {area.heroIntro}
          </p>
          <div class="flex flex-wrap items-center justify-center gap-4 mt-8">
            <a href="#contact" data-contact-context={contactContext} class="inline-flex items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-primary-blue to-primary-pink text-white px-6 py-3 text-sm font-semibold hover:shadow-[0_12px_36px_rgba(16,209,255,0.3)] transition-all duration-300">
              Get a free look at your site
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
            </a>
            <a href="/work" class="inline-flex items-center justify-center gap-2 rounded-xl border border-primary-blue/40 text-primary-blue dark:text-blue-300 px-6 py-3 text-sm font-semibold hover:bg-primary-blue/5 transition-all duration-300">
              See local projects
            </a>
          </div>
        </div>
      </div>
    </header>

    <Section id="local-offer" variant="default">
      <Container>
        <div class="grid gap-6 sm:grid-cols-2 max-w-4xl mx-auto">
          {offers.map((o) => (
            <div class="rounded-2xl border border-light-tertiary dark:border-dark-accent bg-white dark:bg-dark-secondary p-6 transition-all duration-300 hover:border-primary-blue/30 hover:shadow-lg">
              <h2 class="text-lg font-bold text-text-light-primary dark:text-text-dark-primary mb-2">{o.title}</h2>
              <p class="text-sm text-text-light-secondary dark:text-text-dark-secondary leading-relaxed">{o.body}</p>
            </div>
          ))}
        </div>

        <div class="max-w-3xl mx-auto text-center mt-14">
          <p class="text-text-light-secondary dark:text-text-dark-secondary leading-relaxed">
            Monthly plans start at <strong class="text-text-light-primary dark:text-text-dark-primary">$350/mo</strong> — website, AI agent, SEO, and maintenance included.
            <a href="/plans" class="text-primary-blue dark:text-blue-300 font-medium hover:underline">See all plans →</a>
          </p>
        </div>
      </Container>
    </Section>

    <Section id="local-context" variant="alternate">
      <Container>
        <div class="max-w-3xl mx-auto">
          <h2 class="sf-bold text-2xl md:text-3xl font-bold mb-4 text-text-light-primary dark:text-text-dark-primary">{area.angleHeading}</h2>
          <p class="text-text-light-secondary dark:text-text-dark-secondary leading-relaxed mb-4">{area.angleBody}</p>
          <p class="text-text-light-secondary dark:text-text-dark-secondary leading-relaxed mb-6">
            <span class="text-text-light-primary dark:text-text-dark-primary font-medium">Multilingual by default.</span> {area.languageNote}
          </p>
          <p class="text-xs font-semibold uppercase tracking-wide text-text-light-tertiary dark:text-text-dark-tertiary mb-3">Working across {area.name}</p>
          <ul class="flex flex-wrap gap-2">
            {area.neighborhoods.map((hood) => (
              <li class="rounded-full border border-light-tertiary dark:border-dark-accent bg-white dark:bg-dark-secondary px-3 py-1 text-xs text-text-light-secondary dark:text-text-dark-secondary">{hood}</li>
            ))}
          </ul>
        </div>
      </Container>
    </Section>

    {quote && (
      <Section id="local-proof" variant="default">
        <Container>
          <div class="max-w-2xl mx-auto text-center">
            <p class="text-sm font-semibold uppercase tracking-wide text-primary-blue dark:text-blue-300 mb-6">{area.proofHeading}</p>
            <QuoteBlock quote={quote} align="center" />
          </div>
        </Container>
      </Section>
    )}

    <Section id="local-area" variant="alternate">
      <Container>
        <div class="max-w-3xl mx-auto text-center">
          <h2 class="sf-bold text-2xl md:text-3xl font-bold mb-4">
            <span class="apple-gradient-text" data-colorful-title>Serving all of Western Mass</span>
          </h2>
          <p class="text-text-light-secondary dark:text-text-dark-secondary leading-relaxed mb-8">
            Based in Springfield and working with businesses across the region — in person when it helps, remotely when it's faster.
          </p>
          <ul class="flex flex-wrap items-center justify-center gap-2">
            {servedTowns.map((t) => (
              t.slug === area.slug ? (
                <li class="rounded-full border border-primary-blue/40 bg-primary-blue/5 px-4 py-1.5 text-sm font-semibold text-primary-blue dark:text-blue-300">{t.name}</li>
              ) : t.slug ? (
                <li><a href={`/web-design-${t.slug}-ma`} class="inline-block rounded-full border border-light-tertiary dark:border-dark-accent bg-white dark:bg-dark-secondary px-4 py-1.5 text-sm text-text-light-secondary dark:text-text-dark-secondary hover:border-primary-blue/40 hover:text-primary-blue dark:hover:text-blue-300 transition-colors">{t.name}</a></li>
              ) : (
                <li class="rounded-full border border-light-tertiary dark:border-dark-accent bg-white dark:bg-dark-secondary px-4 py-1.5 text-sm text-text-light-secondary dark:text-text-dark-secondary">{t.name}</li>
              )
            ))}
          </ul>
        </div>
      </Container>
    </Section>

    <Section id="local-faq" variant="default">
      <Container>
        <Faq faqs={faqs} />
        <div class="text-center mt-12">
          <a href="#contact" data-contact-context={contactContext} class="inline-flex items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-primary-blue to-primary-pink text-white px-6 py-3 text-sm font-semibold hover:shadow-[0_12px_36px_rgba(16,209,255,0.3)] transition-all duration-300">
            Talk to us about your site
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
          </a>
        </div>
      </Container>
    </Section>

    <DockMenu />
  </main>
</BaseLayout>
