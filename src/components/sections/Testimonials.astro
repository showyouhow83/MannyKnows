---
// Testimonials — renders the given quotes (defaults to the real list from
// src/data/testimonials.ts). Renders NOTHING while the list is empty, so it
// can sit mounted on the homepage until real quotes exist.
import { testimonials as realTestimonials, type Testimonial } from '../../data/testimonials';
import QuoteBlock from '../ui/QuoteBlock.astro';

interface Props {
  items?: Testimonial[];
  heading?: string;
}

const { items = realTestimonials, heading = 'What clients say' } = Astro.props;
---

{items.length > 0 && (
  <section aria-label="Client testimonials" class="py-16">
    <div class="max-w-[1440px] mx-auto px-6 lg:px-8">
      <h2 class="sf-bold text-3xl md:text-4xl font-bold text-center mb-12">
        <span class="apple-gradient-text" data-colorful-title>{heading}</span>
      </h2>
      <div class="grid gap-6 md:grid-cols-3 max-w-5xl mx-auto items-stretch">
        {items.map((t) => (
          <QuoteBlock quote={t} class="h-full" />
        ))}
      </div>
    </div>
  </section>
)}
