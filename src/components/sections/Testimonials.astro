---
// Testimonials — a sliding carousel of the real client quotes (from
// src/data/testimonials.ts). Renders NOTHING while the list is empty, so it can
// sit mounted on the homepage until real quotes exist. Uses the site's global
// Swiper (loaded in BaseLayout) with the redesigned QuoteBlock card.
import { testimonials as realTestimonials, type Testimonial } from '../../data/testimonials';
import QuoteBlock from '../ui/QuoteBlock.astro';

interface Props {
  items?: Testimonial[];
  heading?: string;
}

const { items = realTestimonials, heading = 'What clients say' } = Astro.props;
---

{items.length > 0 && (
  <section aria-label="Client testimonials" class="relative py-16 bg-gradient-to-br from-gray-50/90 via-gray-100/85 to-gray-200/90 dark:from-gray-900/90 dark:via-slate-800/85 dark:to-gray-900/90 border-t border-gray-300/30 dark:border-white/10 transition-colors duration-300 overflow-hidden">
    <div class="max-w-[1440px] mx-auto px-6 lg:px-8">
      <h2 class="sf-bold text-2xl md:text-3xl font-bold text-center mb-10">
        <span class="apple-gradient-text" data-colorful-title>{heading}</span>
      </h2>

      <div class="relative max-w-[1360px] mx-auto px-0 sm:px-12">
        <div class="swiper testimonials-swiper">
          <div class="swiper-wrapper">
            {items.map((t) => (
              <div class="swiper-slide"><QuoteBlock quote={t} class="h-full" /></div>
            ))}
          </div>
          <div class="swiper-pagination"></div>
        </div>

        <button type="button" class="t-nav t-prev" aria-label="Previous testimonial">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </button>
        <button type="button" class="t-nav t-next" aria-label="Next testimonial">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </button>
      </div>
    </div>

    <script is:inline>
      (function () {
        function initTestimonials() {
          if (typeof Swiper === 'undefined') { setTimeout(initTestimonials, 100); return; }
          var el = document.querySelector('.testimonials-swiper');
          if (!el || el.swiper) return;
          new Swiper('.testimonials-swiper', {
            slidesPerView: 1.15,
            spaceBetween: 24,
            rewind: true,
            grabCursor: true,
            autoplay: { delay: 5000, disableOnInteraction: false, pauseOnMouseEnter: true },
            pagination: { el: '.testimonials-swiper .swiper-pagination', clickable: true },
            navigation: { nextEl: '.t-next', prevEl: '.t-prev' },
            breakpoints: {
              640: { slidesPerView: 1.8 },
              1024: { slidesPerView: 2.4 },
              1440: { slidesPerView: 3 },
            },
          });
        }
        if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initTestimonials);
        else initTestimonials();
      })();
    </script>

    <style is:global>
      .testimonials-swiper { padding-bottom: 3rem; }
      .testimonials-swiper .swiper-wrapper { align-items: stretch; }
      .testimonials-swiper .swiper-slide { height: auto; display: flex; }
      .testimonials-swiper .swiper-pagination { bottom: 0 !important; }
      /* 24×24 tap targets (WCAG 2.5.8): the visible 9px dot sits inside a
         transparent border; background-clip keeps the border invisible. */
      .testimonials-swiper .swiper-pagination-bullet {
        width: 23px; height: 23px; background: rgba(120, 130, 145, 0.45);
        border: 7px solid transparent; background-clip: padding-box;
        opacity: 1; transition: width .3s ease, background .3s ease;
        margin: 0 1px !important;
      }
      .testimonials-swiper .swiper-pagination-bullet-active {
        width: 40px; border-radius: 12px;
        background: linear-gradient(135deg, #0071e3, #ff4faa);
        background-clip: padding-box;
      }
      .t-nav {
        position: absolute; top: calc(50% - 1.5rem); transform: translateY(-50%);
        z-index: 10; width: 42px; height: 42px; border-radius: 9999px;
        display: flex; align-items: center; justify-content: center;
        background: #ffffff; color: #334155; border: 1px solid rgba(0, 0, 0, 0.08);
        box-shadow: 0 6px 18px rgba(16, 24, 40, 0.1); cursor: pointer;
        transition: color .2s ease, border-color .2s ease, transform .2s ease;
      }
      .t-nav svg { width: 20px; height: 20px; }
      .t-nav:hover { color: #0071e3; border-color: rgba(0, 113, 227, 0.4); }
      .t-prev { left: 0; }
      .t-next { right: 0; }
      :root.dark .t-nav { background: #141b23; color: #cbd5e1; border-color: rgba(255, 255, 255, 0.1); }
      :root.dark .t-nav:hover { color: #4aa8ff; border-color: rgba(74, 168, 255, 0.4); }
      .t-nav.swiper-button-disabled { opacity: 0.35; pointer-events: none; }
      @media (max-width: 639px) { .t-nav { display: none; } }
    </style>
  </section>
)}
