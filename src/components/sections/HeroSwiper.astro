---
// HeroSwiper.astro — homepage hero carousel.
// A custom "vanilla" coverflow carousel (NO Swiper / no third-party slider),
// modeled on the slpainting.co hero: a large centered slide with two scaled,
// faded slides peeking on each side; 8s autoplay, hover/tab pause, drag + swipe,
// infinite wrap-around. Behavior constants live in the inline <script> below.

export interface Slide {
  image: string;        // Unsplash photo base URL (no query params)
  title: string;        // <= 34 chars
  description?: string; // <= 120 chars
  href?: string;        // click target for the centered slide
}

export interface Props {
  slides?: Slide[];
}

// Default slides — the four monthly plans plus the AI Team. Five slides is the
// clean minimum for a 2-per-side coverflow (every slide holds a unique position,
// so the wrap-around never has to show one slide in two places).
const defaultSlides: Slide[] = [
  {
    image: 'https://images.unsplash.com/photo-1460925895917-afdab827c52f',
    title: 'Smart Website (AI) — from $350/mo',
    description: 'A multilingual site with an AI Sales & Booking Agent that answers, sells, and books jobs 24/7.',
    href: '/plans/smart-website',
  },
  {
    image: 'https://images.unsplash.com/photo-1562259949-e8e7689d7828',
    title: 'Online Store (AI) — from $650/mo',
    description: "A full online store, set up with years of eCommerce experience from Bob's Discount Furniture.",
    href: '/plans/online-store',
  },
  {
    image: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71',
    title: 'Business Ads — from $950/mo',
    description: 'Social media, Google & social ads, SEO, and your Google Business Profile — get seen everywhere.',
    href: '/plans/business-ads',
  },
  {
    image: 'https://images.unsplash.com/photo-1518770660439-4636190af475',
    title: 'Multimedia Agency — from $1,800/mo',
    description: 'We design, build, promote, and optimize everything — your full media & tech team.',
    href: '/plans/multimedia-agency',
  },
  {
    image: 'https://images.unsplash.com/photo-1522071820081-009f0129c71c',
    title: 'Your AI team, ready to hire',
    description: 'Sales, research, copy, graphics, voice — AI agents built around your business, run on demand.',
    href: '/ai-team',
  },
];

const { slides = defaultSlides } = Astro.props;

// Cloudflare/Unsplash-style responsive crops: 16:9, desktop 1200×675, mobile 640×360.
const desktopSrc = (base: string) => `${base}?w=1200&h=675&fit=crop&crop=entropy&q=62&auto=format`;
const mobileSrc = (base: string) => `${base}?w=640&h=360&fit=crop&crop=entropy&q=60&auto=format`;
---

<section class="hero-carousel-section">
  <div class="hero-carousel" id="heroCarousel" aria-roledescription="carousel" aria-label="Featured plans and services">
    <div class="hero-track" id="heroTrack">
      {slides.map((slide, i) => (
        <a
          class="hero-slide"
          data-index={i}
          href={slide.href ?? '#'}
          aria-label={slide.title}
          draggable="false"
        >
          <picture>
            <source media="(min-width: 768px)" srcset={desktopSrc(slide.image)} />
            <img
              src={mobileSrc(slide.image)}
              alt={slide.title}
              width="1200"
              height="675"
              draggable="false"
              loading={i === 0 ? 'eager' : 'lazy'}
              fetchpriority={i === 0 ? 'high' : undefined}
              decoding="async"
            />
          </picture>
          <div class="hero-slide-content">
            <h2>{slide.title}</h2>
            {slide.description && <p>{slide.description}</p>}
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    var carousel = document.getElementById('heroCarousel');
    var track = document.getElementById('heroTrack');
    if (!carousel || !track) return;

    // Anchors + images are natively draggable; that hijacks the pointer and kills
    // both custom swipe and click-through. Suppress the browser's own drag.
    track.addEventListener('dragstart', function (e) { e.preventDefault(); });
    var slides = Array.prototype.slice.call(track.querySelectorAll('.hero-slide'));
    var n = slides.length;
    if (!n) return;

    // --- behavior constants (match slpainting.co) ---
    var AUTOPLAY_DELAY = 8000;
    var SIDE_SLIDES = 2;
    var SCALE_STEP = 0.3;    // center 1.0 → ±1 0.7 → ±2 0.4
    var OPACITY_STEP = 0.35; // center 1.0 → ±1 0.65 → ±2 0.30
    var TRANSLATE_FACTOR = 0.55;
    var SWIPE_THRESHOLD = 50;
    var DRAG_DETECT = 10;

    var current = 0;
    var timer = null;

    // shortest signed distance from `current` to slide `i`, wrapping around
    function offsetOf(i) {
      var o = i - current;
      if (o > n / 2) o -= n;
      if (o < -n / 2) o += n;
      return o;
    }

    function render() {
      var w = slides[0].offsetWidth || track.offsetWidth || 1;
      for (var i = 0; i < n; i++) {
        var el = slides[i];
        var o = offsetOf(i);
        var a = Math.abs(o);
        if (a > SIDE_SLIDES) {
          el.style.opacity = '0';
          el.style.transform = 'translateX(-50%) scale(0)';
          el.style.zIndex = '0';
          el.style.pointerEvents = 'none';
          el.setAttribute('aria-hidden', 'true');
          el.tabIndex = -1;
          el.classList.remove('is-center');
          continue;
        }
        var translate = o * w * TRANSLATE_FACTOR;
        el.style.transform = 'translateX(calc(-50% + ' + translate + 'px)) scale(' + (1 - a * SCALE_STEP) + ')';
        el.style.opacity = a === 0 ? '1' : String(1 - a * OPACITY_STEP);
        el.style.zIndex = a === 0 ? '10' : a === 1 ? '5' : '2';
        el.style.pointerEvents = a <= 1 ? 'auto' : 'none';
        el.setAttribute('aria-hidden', a === 0 ? 'false' : 'true');
        el.tabIndex = a === 0 ? 0 : -1;
        if (o === 0) el.classList.add('is-center');
        else el.classList.remove('is-center');
      }
    }

    function goTo(i) { current = ((i % n) + n) % n; render(); restart(); }
    function next() { goTo(current + 1); }
    function prev() { goTo(current - 1); }

    function play() { if (!timer) timer = setInterval(next, AUTOPLAY_DELAY); }
    function pause() { if (timer) { clearInterval(timer); timer = null; } }
    function restart() { pause(); play(); }

    // click: the centered slide follows its link; a side slide navigates to it
    slides.forEach(function (el, i) {
      el.addEventListener('click', function (e) {
        if (offsetOf(i) !== 0) { e.preventDefault(); goTo(i); }
      });
    });

    // drag / swipe (pointer events cover mouse + touch)
    var startX = 0, dx = 0, dragging = false, moved = false;
    track.addEventListener('pointerdown', function (e) {
      dragging = true; moved = false; startX = e.clientX; dx = 0;
      pause();
      try { track.setPointerCapture(e.pointerId); } catch (err) {}
    });
    track.addEventListener('pointermove', function (e) {
      if (!dragging) return;
      dx = e.clientX - startX;
      if (Math.abs(dx) > DRAG_DETECT) moved = true;
    });
    function endDrag() {
      if (!dragging) return;
      dragging = false;
      if (Math.abs(dx) > SWIPE_THRESHOLD) { dx < 0 ? next() : prev(); }
      else { play(); }
      // if it was a drag, swallow the click that fires next so we don't follow a link
      if (moved) {
        var blocker = function (ev) { ev.preventDefault(); ev.stopPropagation(); track.removeEventListener('click', blocker, true); };
        track.addEventListener('click', blocker, true);
        setTimeout(function () { track.removeEventListener('click', blocker, true); }, 350);
      }
    }
    track.addEventListener('pointerup', endDrag);
    track.addEventListener('pointercancel', function () { dragging = false; play(); });

    // pause on hover and when the tab is hidden
    carousel.addEventListener('mouseenter', pause);
    carousel.addEventListener('mouseleave', play);
    document.addEventListener('visibilitychange', function () { document.hidden ? pause() : play(); });

    // keyboard: left/right when the carousel has focus within
    carousel.addEventListener('keydown', function (e) {
      if (e.key === 'ArrowLeft') { e.preventDefault(); prev(); }
      else if (e.key === 'ArrowRight') { e.preventDefault(); next(); }
    });

    window.addEventListener('resize', render);

    // first paint without the 0.6s transition so slides don't fly out from center
    track.classList.add('no-anim');
    render();
    requestAnimationFrame(function () {
      requestAnimationFrame(function () { track.classList.remove('no-anim'); });
    });
    play();
  })();
</script>

<style>
  .hero-carousel-section {
    width: 100%;
    padding: 0.5rem 0 2rem;
  }

  .hero-carousel {
    position: relative;
    max-width: 1920px;
    margin: 0 auto;
    overflow: hidden;
    height: clamp(220px, 31vw, 565px);
  }

  .hero-track {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .hero-slide {
    position: absolute;
    top: 0;
    left: 50%;
    width: clamp(300px, 55vw, 1000px);
    max-width: calc(100% - 48px);
    height: 100%;
    transform: translateX(-50%);
    transform-origin: center center;
    border-radius: 16px;
    overflow: hidden;
    display: block;
    text-decoration: none;
    background: #18212b;
    opacity: 0;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.25);
    transition: transform 0.6s cubic-bezier(0.25, 0.1, 0.25, 1),
                opacity 0.6s cubic-bezier(0.25, 0.1, 0.25, 1),
                box-shadow 0.6s cubic-bezier(0.25, 0.1, 0.25, 1);
    will-change: transform, opacity;
    user-select: none;
    -webkit-user-select: none;
    -webkit-user-drag: none;
    touch-action: pan-y;
  }

  /* Pre-JS fallback: show the first slide centered (it's the LCP element). */
  .hero-slide:first-child { opacity: 1; z-index: 10; }

  .hero-track.no-anim .hero-slide { transition: none !important; }

  .hero-slide.is-center { box-shadow: 0 0 30px rgba(0, 0, 0, 0.5); cursor: pointer; }

  .hero-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 16px;
    pointer-events: none;
    -webkit-user-drag: none;
  }

  .hero-slide-content {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 48px 24px 20px;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.8), rgba(0, 0, 0, 0.5) 50%, transparent);
    border-radius: 0 0 16px 16px;
    color: #fff;
    pointer-events: none;
  }

  .hero-slide-content h2 {
    margin: 0;
    font-size: 22px;
    font-weight: 700;
    line-height: 1.2;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.4);
    transition: color 0.3s ease;
  }

  .hero-slide.is-center:hover .hero-slide-content h2 { color: #10d1ff; }

  .hero-slide-content p {
    margin: 8px 0 0;
    font-size: 14px;
    font-weight: 400;
    line-height: 1.4;
    color: rgba(255, 255, 255, 0.85);
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    overflow: hidden;
  }

  .hero-slide:focus-visible { outline: 3px solid #10d1ff; outline-offset: 3px; }

  /* Tablet */
  @media (max-width: 768px) {
    .hero-carousel { height: 50vw; }
    .hero-slide { width: 85vw; }
    .hero-slide-content { padding: 30px 18px 18px; }
  }

  /* Small mobile */
  @media (max-width: 480px) {
    .hero-carousel { height: 400px; }
    .hero-slide { width: calc(100% - 16px); }
    .hero-slide-content { padding: 24px 14px 14px; }
    .hero-slide-content h2 { font-size: 1rem; }
    .hero-slide-content p { font-size: 13px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-slide { transition: opacity 0.3s ease; }
  }
</style>
