---
// Shared template for the per-profession landing pages. Driven entirely by a
// Profession record (src/data/professions.ts). Thin page wrappers live at
// src/pages/websites-for-<slug>.astro.
import BaseLayout from '../../layouts/BaseLayout.astro';
import NavBar from '../navigation/NavBar.astro';
import DockMenu from '../navigation/DockMenu.astro';
import ChatBox from '../ui/ChatBox.astro';
import Section from '../layout/Section.astro';
import Container from '../layout/Container.astro';
import QuoteBlock from '../ui/QuoteBlock.astro';
import Faq from '../ui/Faq.astro';
import Illustration from '../illustrations/Illustration.astro';
import { getTestimonial } from '../../data/testimonials';
import { professions, type Profession } from '../../data/professions';

interface Props {
  profession: Profession;
}
const { profession: p } = Astro.props;

const quote = p.proofBusiness ? getTestimonial(p.proofBusiness) : undefined;
const others = professions.filter((x) => x.slug !== p.slug);
const contactContext = `Website for ${p.name}`;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: p.faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout title={p.metaTitle} description={p.metaDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <main class="relative bg-light-primary dark:bg-dark-primary text-text-light-primary dark:text-text-dark-primary min-h-screen transition-colors duration-300">

    <header class="relative bg-gradient-to-t from-gray-50/50 via-gray-100/30 to-gray-50/20 dark:from-gray-900/60 dark:via-slate-800/40 dark:to-gray-900/30 transition-colors duration-300">
      <NavBar />
      <nav aria-label="breadcrumb" class="max-w-[1440px] mx-auto px-4 lg:px-6 pt-6 pb-4">
        <ol class="flex flex-wrap items-center gap-2 text-sm text-text-light-secondary dark:text-text-dark-secondary">
          <li><a href="/" class="hover:text-primary-blue transition-colors">Home</a></li>
          <li class="flex items-center"><span class="mx-2 text-text-light-tertiary dark:text-text-dark-tertiary">/</span><a href="/services" class="hover:text-primary-blue transition-colors">Services</a></li>
          <li class="flex items-center"><span class="mx-2 text-text-light-tertiary dark:text-text-dark-tertiary">/</span><span class="text-text-light-primary dark:text-text-dark-primary font-medium">Websites for {p.name}</span></li>
        </ol>
      </nav>
      <div class="pb-10 px-4">
        <Container>
          <div class="max-w-5xl mx-auto grid lg:grid-cols-2 gap-8 lg:gap-12 items-center">
            <div class="order-2 lg:order-1">
              <div class="rounded-2xl border border-light-tertiary dark:border-dark-accent bg-gradient-to-br from-primary-blue/[0.05] via-transparent to-primary-pink/[0.05] px-6 py-10 flex items-center justify-center">
                <Illustration kind={p.illustration} class="w-full max-w-sm" />
              </div>
            </div>
            <div class="order-1 lg:order-2 text-center lg:text-left">
              <span class="inline-block bg-gradient-to-r from-primary-blue/10 via-purple-500/10 to-primary-pink/10 text-primary-blue px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider mb-4">{p.badge}</span>
              <h1 class="sf-bold apple-headline text-4xl md:text-5xl lg:text-6xl mb-5 leading-tight">
                <span class="apple-gradient-text" data-colorful-title>{p.h1}</span>
              </h1>
              <p class="text-lg text-text-light-secondary dark:text-text-dark-secondary leading-relaxed mb-6">{p.heroIntro}</p>
              <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
                <a href="#contact" data-contact-context={contactContext} class="inline-flex items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-primary-blue to-primary-pink text-white px-6 py-3 text-sm font-semibold transition-all duration-300">
                  Get a free look at your site
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
                </a>
                <a href="/plans" class="inline-flex items-center justify-center gap-2 rounded-xl border border-primary-blue/40 text-primary-blue dark:text-blue-300 px-6 py-3 text-sm font-semibold hover:bg-primary-blue/5 transition-all duration-300">
                  See plans from $349/mo
                </a>
              </div>
            </div>
          </div>
        </Container>
      </div>
    </header>

    <!-- The problems this trade actually feels -->
    <Section id="prof-pains" variant="default">
      <Container>
        <div class="max-w-3xl mx-auto text-center mb-10">
          <h2 class="sf-bold text-2xl md:text-3xl font-bold">
            <span class="apple-gradient-text" data-colorful-title>What’s quietly costing you jobs</span>
          </h2>
        </div>
        <div class="grid gap-6 md:grid-cols-3 max-w-5xl mx-auto">
          {p.painPoints.map((pt) => (
            <div class="rounded-2xl border border-light-tertiary dark:border-dark-accent bg-white dark:bg-dark-secondary p-6">
              <h3 class="text-lg font-bold text-text-light-primary dark:text-text-dark-primary mb-2">{pt.title}</h3>
              <p class="text-sm text-text-light-secondary dark:text-text-dark-secondary leading-relaxed">{pt.body}</p>
            </div>
          ))}
        </div>
      </Container>
    </Section>

    <!-- What we do about it -->
    <Section id="prof-offer" variant="alternate">
      <Container>
        <div class="max-w-3xl mx-auto text-center mb-10">
          <h2 class="sf-bold text-2xl md:text-3xl font-bold">
            <span class="apple-gradient-text" data-colorful-title>What you get</span>
          </h2>
        </div>
        <div class="grid gap-6 sm:grid-cols-2 max-w-4xl mx-auto">
          {p.offer.map((o) => (
            <div class="rounded-2xl border border-light-tertiary dark:border-dark-accent bg-white dark:bg-dark-secondary p-6 flex items-start gap-4">
              <svg class="w-6 h-6 flex-shrink-0 text-green-500 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              <div>
                <h3 class="text-lg font-bold text-text-light-primary dark:text-text-dark-primary mb-1">{o.title}</h3>
                <p class="text-sm text-text-light-secondary dark:text-text-dark-secondary leading-relaxed">{o.body}</p>
              </div>
            </div>
          ))}
        </div>
        <div class="max-w-3xl mx-auto text-center mt-12">
          <p class="text-text-light-secondary dark:text-text-dark-secondary leading-relaxed">
            Everything on one monthly plan from <strong class="text-text-light-primary dark:text-text-dark-primary">$349/mo</strong> — no big upfront bill.
            <a href="/plans" class="text-primary-blue dark:text-blue-300 font-medium hover:underline">See all plans →</a>
          </p>
        </div>
      </Container>
    </Section>

    {quote && (
      <Section id="prof-proof" variant="default">
        <Container>
          <div class="max-w-2xl mx-auto text-center">
            <p class="text-sm font-semibold uppercase tracking-wide text-primary-blue dark:text-blue-300 mb-6">{p.proofHeading}</p>
            <QuoteBlock quote={quote} align="center" />
          </div>
        </Container>
      </Section>
    )}

    <Section id="prof-faq" variant="alternate">
      <Container>
        <div class="max-w-3xl mx-auto">
          <Faq faqs={p.faqs} />
        </div>
      </Container>
    </Section>

    <!-- Cross-links to the other verticals -->
    <Section id="prof-others" variant="default">
      <Container>
        <div class="max-w-4xl mx-auto text-center">
          <p class="text-xs font-semibold uppercase tracking-wide text-text-light-tertiary dark:text-text-dark-tertiary mb-5">We also build for</p>
          <div class="flex flex-wrap items-center justify-center gap-3">
            {others.map((o) => (
              <a href={`/websites-for-${o.slug}`} class="inline-flex items-center rounded-full border border-light-tertiary dark:border-dark-accent bg-white dark:bg-dark-secondary px-4 py-1.5 text-sm text-text-light-secondary dark:text-text-dark-secondary hover:border-primary-blue/40 hover:text-primary-blue dark:hover:text-blue-300 transition-colors">
                {o.name}
              </a>
            ))}
          </div>
          <div class="mt-10">
            <a href="#contact" data-contact-context={contactContext} class="inline-flex items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-primary-blue to-primary-pink text-white px-6 py-3 text-sm font-semibold transition-all duration-300">
              Talk to us about your {p.name.toLowerCase().replace(/s$/, '')} site
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
            </a>
          </div>
        </div>
      </Container>
    </Section>

    <ChatBox />
    <DockMenu />
  </main>
</BaseLayout>
