---
// Brand spot illustrations — one visual system: thin currentColor outlines that
// adapt to light/dark, a blue→pink gradient accent, and a "spark" motif for AI.
// Usage: <Illustration kind="website" class="w-full max-w-md" />
// Vector + inline, so they add near-zero page weight and stay razor-sharp.
interface Props {
  kind: 'website' | 'seo' | 'agent' | 'audit' | 'automation' | 'store' | 'ads' | 'multimedia';
  class?: string;
}
