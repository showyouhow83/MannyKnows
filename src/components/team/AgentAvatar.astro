---
// One avatar per AI Team member. Shared identity: a friendly gradient "bot"
// head (brand blue→pink) with a dark visor + eyes — so the roster reads as one
// team. Each agent is told apart by a specialty emblem in the corner badge.
// Inline SVG: near-zero page weight, razor-sharp, adapts to light/dark.
import type { AgentId } from '../../data/aiTeam';

interface Props {
  agent: AgentId;
  class?: string;
}
const { agent, class: className = '' } = Astro.props;

// Specialty emblems, drawn centered on the origin (fits within ~r9), placed
// inside a white badge at the bottom-right of the head.
const emblems: Record<AgentId, string> = {
  // chat bubble — sales, booking & support
  manny: '<rect x="-7" y="-6" width="14" height="10" rx="3" fill="currentColor"/><path d="M-2.6 3.4 L-2.6 7.6 L2.2 3.4 Z" fill="currentColor"/>',
  // magnifying glass — research
  eve: '<circle cx="-1.6" cy="-1.6" r="5" fill="none" stroke="currentColor" stroke-width="2.4"/><path d="M2.2 2.2 L6.6 6.6" stroke="currentColor" stroke-width="2.8" stroke-linecap="round"/>',
  // pencil — copy
  elly: '<path d="M-6.2 6.2 L-4.8 1.6 L2.6 -5.8 L5.8 -2.6 L-1.6 4.8 Z" fill="currentColor"/><path d="M2.6 -5.8 L5.8 -2.6" stroke="#fff" stroke-width="1.3"/>',
  // play triangle — design & video
  eny: '<path d="M-4 -6 L6.2 0 L-4 6 Z" fill="currentColor"/>',
  // soundwave — voice
  mimi: '<g stroke="currentColor" stroke-width="2.3" stroke-linecap="round"><path d="M-6 0 v0"/><path d="M-3 -4 v8"/><path d="M0 -7 v14"/><path d="M3 -4.5 v9"/><path d="M6 -2 v4"/></g>',
  // star — reviews
  upie: '<path d="M0 -6.4 L1.9 -2 L6.6 -1.6 L3 1.4 L4.1 6 L0 3.4 L-4.1 6 L-3 1.4 L-6.6 -1.6 L-1.9 -2 Z" fill="currentColor"/>',
  // paper plane — publishing & social
  bap: '<path d="M7 -6.4 L-6.6 -0.6 L-1.2 1.4 L1 6.6 L2.8 1.6 Z" fill="currentColor"/>',
};

const emblem = emblems[agent] ?? '';
// Unique gradient id per instance — the same agent can appear more than once on
// a page (hero + roster), and duplicate element IDs are invalid HTML.
const gid = `ag-${agent}-${Math.random().toString(36).slice(2, 9)}`;
const label = agent.charAt(0).toUpperCase() + agent.slice(1);

const svg = `<svg viewBox="0 0 96 100" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:auto;display:block" role="img" aria-label="${label}, an AI Team agent">
  <defs>
    <linearGradient id="${gid}" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#0071e3"/><stop offset="1" stop-color="#ff4faa"/>
    </linearGradient>
  </defs>
  <!-- antenna -->
  <path d="M44 14 v-7" stroke="url(#${gid})" stroke-width="3.4" stroke-linecap="round"/>
  <circle cx="44" cy="5.4" r="3.6" fill="url(#${gid})"/>
  <!-- head -->
  <circle cx="44" cy="48" r="34" fill="url(#${gid})"/>
  <circle cx="44" cy="48" r="34" fill="#ffffff" opacity="0.07"/>
  <!-- little ears -->
  <rect x="6" y="42" width="6" height="14" rx="3" fill="url(#${gid})"/>
  <rect x="76" y="42" width="6" height="14" rx="3" fill="url(#${gid})"/>
  <!-- visor + eyes -->
  <rect x="24" y="40" width="40" height="19" rx="9.5" fill="#0b1220" opacity="0.9"/>
  <circle cx="36" cy="49.5" r="3.4" fill="#ffffff"/>
  <circle cx="52" cy="49.5" r="3.4" fill="#ffffff"/>
  <!-- specialty badge (emblem forced to brand blue so it stays visible in dark mode) -->
  <circle cx="74" cy="80" r="17" fill="#ffffff" stroke="url(#${gid})" stroke-width="2.4"/>
  <g transform="translate(74 80)" style="color:#0071e3">${emblem}</g>
</svg>`;
---

<div class={className} set:html={svg} />
