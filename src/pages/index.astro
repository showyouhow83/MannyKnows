---
// Import the Layout component
import BaseLayout from '../layouts/BaseLayout.astro';
import MarqueeSimple from '../components/MarqueeSimple.astro';
import NavBar from '../components/navigation/NavBar.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import HeroSwiper from '../components/sections/HeroSwiper.astro';
import BlogHighlights from '../components/sections/BlogHighlights.astro';
// Reviews section is temporarily hidden from the homepage until we have a real
// client testimonial to display. The fabricated testimonials were removed from
// ReviewsSection.astro — re-import and re-enable below once a real review is ready.
// import ReviewsSection from '../components/sections/ReviewsSection.astro';
import DockMenu from '../components/navigation/DockMenu.astro';
import PageSection from '../components/layout/PageSection.astro';
import LinkBanner from '../components/layout/LinkBanner.astro';
import SelectedWork from '../components/sections/SelectedWork.astro';
import IdeaLaunchpad from '../components/sections/IdeaLaunchpad.astro';
import PricingPlans from '../components/sections/PricingPlans.astro';
import ChatBox from '../components/ui/ChatBox.astro';

// ========================================
// LOCAL SEO — structured data (LocalBusiness / Person / WebSite)
// Real NAP, service area, and social profiles for Manny / MannyKnows.
// ========================================
const siteUrl = 'https://mannyknows.com';
const PHONE_TEL = '+14133618451';
const EMAIL = 'mm@mannyknows.com';

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'ProfessionalService',
      '@id': `${siteUrl}/#business`,
      name: 'MannyKnows',
      description:
        'Custom apps, websites, and AI automation for established small businesses across Springfield and Western Massachusetts. Manny turns the manual processes that slow a business down into software that runs them — from ecommerce stores and lead-to-job systems to data pipelines and API integrations.',
      url: siteUrl,
      email: EMAIL,
      telephone: PHONE_TEL,
      image: `${siteUrl}/favicon.svg`,
      priceRange: '$$',
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Springfield',
        addressRegion: 'MA',
        addressCountry: 'US',
      },
      areaServed: [
        { '@type': 'City', name: 'Springfield, Massachusetts' },
        { '@type': 'City', name: 'Chicopee, Massachusetts' },
        { '@type': 'City', name: 'Holyoke, Massachusetts' },
        { '@type': 'City', name: 'Westfield, Massachusetts' },
        { '@type': 'City', name: 'West Springfield, Massachusetts' },
        { '@type': 'City', name: 'Agawam, Massachusetts' },
        { '@type': 'City', name: 'Northampton, Massachusetts' },
        { '@type': 'City', name: 'Amherst, Massachusetts' },
        { '@type': 'AdministrativeArea', name: 'Pioneer Valley' },
        { '@type': 'AdministrativeArea', name: 'Hampden County, Massachusetts' },
        { '@type': 'AdministrativeArea', name: 'Western Massachusetts' },
      ],
      founder: { '@id': `${siteUrl}/#manny` },
      sameAs: [
        'https://www.linkedin.com/in/mrmanu/',
        'https://www.youtube.com/@MannyKnows-com/posts',
        'https://www.tiktok.com/@mannyknowsai',
      ],
    },
    {
      '@type': 'Person',
      '@id': `${siteUrl}/#manny`,
      name: 'Manny',
      jobTitle: 'Founder',
      worksFor: { '@id': `${siteUrl}/#business` },
      url: siteUrl,
      sameAs: ['https://www.linkedin.com/in/mrmanu/'],
      knowsAbout: [
        'Custom app & software development for small businesses',
        'Turning manual business processes into software',
        'Web development',
        'AI automation',
        'CRM development',
        'Local SEO',
        'Google Business Profile',
        'eCommerce development',
        'API integrations and data pipelines',
      ],
    },
    {
      '@type': 'WebSite',
      '@id': `${siteUrl}/#website`,
      url: siteUrl,
      name: 'MannyKnows',
      publisher: { '@id': `${siteUrl}/#business` },
      inLanguage: 'en-US',
    },
  ],
};
// ========================================
// NAVBAR CONFIGURATION
// ========================================
const NAVBAR_CONFIG = {
	// Search gradient animations in navbar
	searchGradientEnabled: true,
	searchScrollDelay: 0,
	
	// Debug mode for development
	debugMode: false,
};
---

<BaseLayout
	title="Websites, SEO & Software for Western Mass Businesses | MannyKnows"
	description="A local father-and-son shop in Springfield. I build and optimize the websites, technical SEO, and software that small Western Massachusetts businesses run on — real results, long-term, and you work directly with me."
>
	<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
	<main class="relative bg-light-primary dark:bg-dark-primary text-text-light-primary dark:text-text-dark-primary min-h-screen transition-colors duration-300">
		<!-- Marquee Announcement Section -->
		<MarqueeSimple />

		<!-- Header Container with Subtle Background -->
		<header class="relative bg-gradient-to-t from-gray-50/50 via-gray-100/30 to-gray-50/20 dark:from-gray-900/60 dark:via-slate-800/40 dark:to-gray-900/30 transition-colors duration-300">
            <!-- Navigation -->
            <NavBar
				animationConfig={{
					searchGradientEnabled: NAVBAR_CONFIG.searchGradientEnabled,
					debugMode: NAVBAR_CONFIG.debugMode,
					searchScrollDelay: NAVBAR_CONFIG.searchScrollDelay
				}}
			/>

            <!-- Hero Section -->
            <HeroSection
                badge="Springfield · a local father-and-son shop"
                title="I build the websites, SEO, and "
                highlightedText="software local businesses run on"
                titleAfter="."
                subtitle="You work directly with me — 20 years turning messy operations into software that just works, backed by real results, not buzzwords. My son and I are local, and we're in it for the long haul, not a one-off invoice."
            />

            <!-- Hero Swiper Slider -->
            <HeroSwiper />

            <!-- Brand mascot — floats at the lower-left of the header, below the slider -->
            <div class="astronaut-mascot hidden lg:block" aria-hidden="true"></div>
        </header>

		<!-- Latest Work (real client sites) — portfolio proof, placed right after the hero -->
		<PageSection
			id="work"
			badge="Proof"
			title="Latest Work"
			subtitle="Real sites for real businesses — built to rank and to keep running for years, not months. Click any to see it live."
			variant="alternate"
		>
			<SelectedWork />
		</PageSection>

		<!-- Services — the full section now lives at /services (kept, not deleted);
		     the homepage shows a banner that links to it. -->
		<LinkBanner
			badge="Consulting · Web · SEO · AI · Automation"
			title="Find the friction. Then fix it."
			text="I map how your business actually runs, then fix what's slowing it down — websites, technical SEO, automation, and AI. Twenty years of doing exactly this."
			href="/services"
			cta="Explore services"
			variant="alternate"
		/>

		<!-- Plans — monthly retainers, "starting at" pricing, tailored per client -->
		<PageSection
			id="plans"
			badge="Monthly plans"
			title="Plans that grow with you"
			subtitle="Hire me like a teammate, not a vendor. Start where you need help most — a site that books jobs, an online store, full marketing, or your own tech team — and we shape it around your business. Month-to-month, and you can change it any time."
		>
			<PricingPlans />
		</PageSection>

		<!-- Idea Launchpad — bring an idea, I build & market it (partnership offer) -->
		<PageSection
			id="launchpad"
			badge="Got an idea?"
			title="Have an idea? Let's build it together."
			subtitle="No upfront cost. You bring the idea; I design, build, and market it as your technical co-founder — and we co-own what we launch. If it has real legs, we agree on a fair split. Real skin in the game, both sides."
		>
			<IdeaLaunchpad />
		</PageSection>

		<!-- How it works — the full section now lives at /how-it-works; banner links to it. -->
		<LinkBanner
			badge="How it works"
			title="From process to app"
			text="From the first call to working software: I find the process slowing you down and turn it into something that runs it for you. No jargon, no mystery."
			href="/how-it-works"
			cta="See how it works"
		/>

		<!-- "New Playbooks" (blog highlights) — moved here so it sits last, right above the footer. -->
		<BlogHighlights />

		<!-- Customer Reviews Section — hidden until a real client testimonial (e.g. SL Painting) is ready.
		     Fabricated testimonials were removed; see ReviewsSection.astro. -->
		<!-- <ReviewsSection /> -->

		<!-- Chat Box -->
		<ChatBox />

		<!-- Floating Dock Menu -->
		<DockMenu />
	</main>
</BaseLayout>

<script>
  // Handle URL parameters for chat opening and reference tracking
  document.addEventListener('DOMContentLoaded', () => {
    const urlParams = new URLSearchParams(window.location.search);
    const chatParam = urlParams.get('chat');
    const refParam = urlParams.get('ref');
    
    // Auto-open chat if ?chat=open parameter is present
    if (chatParam === 'open') {
      // Small delay to ensure ChatBox component is initialized
      setTimeout(() => {
        const chatToggle = document.getElementById('dockChatToggle') || 
                          document.getElementById('topChatToggle') || 
                          document.getElementById('heroChatButton');
        
        if (chatToggle) {
          chatToggle.click();
          
          // If there's a reference parameter, store it and trigger contextual greeting
          if (refParam) {
            try {
              sessionStorage.setItem('mk_chat_reference', refParam);
              console.log('📧 Chat opened with reference:', refParam);
              
              // Trigger contextual AI greeting after chat opens
              setTimeout(() => {
                const chatInput = document.getElementById('chatBoxInput');
                if (chatInput && (window as any).triggerContextualGreeting) {
                  (window as any).triggerContextualGreeting(refParam);
                }
              }, 1000);
            } catch (e) {
              console.warn('Could not store chat reference:', e);
            }
          }
        } else {
          console.warn('Chat toggle button not found');
        }
      }, 500);
    }
    
    // Clean up URL parameters after processing (optional - keeps URL clean)
    if (chatParam || refParam) {
      const cleanUrl = window.location.pathname;
      window.history.replaceState({}, document.title, cleanUrl);
    }
  });
</script>

<style>
  /* Brand astronaut mascot — anchored to the lower-left of the header (below the
     slider). CSS background-image so a missing file shows nothing until the PNG
     lands at public/art/astronaut-rocket.png. */
  .astronaut-mascot {
    position: absolute;
    bottom: 10vh;
    left: max(0.75rem, 1.5vw);
    width: clamp(160px, 25vw, 530px);
    aspect-ratio: 1 / 1;
    background: url('/art/astronaut-rocket.png') center / contain no-repeat;
    pointer-events: none;
    z-index: 20;
    opacity: 0.95;
    filter: drop-shadow(0 14px 26px rgba(0, 0, 0, 0.16));
    animation: astronautFloat 6s ease-in-out infinite;
    will-change: transform;
  }
  @keyframes astronautFloat {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50%      { transform: translateY(-12px) rotate(3deg); }
  }
  @media (prefers-reduced-motion: reduce) {
    .astronaut-mascot { animation: none; }
  }
</style>