---
// Import the Layout component
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
import NavBar from '../components/navigation/NavBar.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import HeroSwiper from '../components/sections/HeroSwiper.astro';
import BlogHighlights from '../components/sections/BlogHighlights.astro';
// Reviews section is temporarily hidden from the homepage until we have a real
// client testimonial to display. The fabricated testimonials were removed from
// Testimonials render from src/data/testimonials.ts — hidden while the real
// list is empty; add real quotes there to make the section appear.
import Testimonials from '../components/sections/Testimonials.astro';
import DockMenu from '../components/navigation/DockMenu.astro';
import PageSection from '../components/layout/PageSection.astro';
import SelectedWork from '../components/sections/SelectedWork.astro';
import IdeaLaunchpad from '../components/sections/IdeaLaunchpad.astro';
import PricingPlans from '../components/sections/PricingPlans.astro';
import ChatBox from '../components/ui/ChatBox.astro';

// ========================================
// LOCAL SEO — structured data (LocalBusiness / Person / WebSite)
// Real NAP, service area, and social profiles for Manny / MannyKnows.
// ========================================
const siteUrl = 'https://mannyknows.com';
const PHONE_TEL = '+14133618451';
const EMAIL = 'mk@mannyknows.com';

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'ProfessionalService',
      '@id': `${siteUrl}/#business`,
      name: 'MannyKnows',
      legalName: 'Manuel Medina Rodriguez',
      founder: { '@type': 'Person', name: 'Manuel Medina Rodriguez', alternateName: 'Manny' },
      description:
        'Custom apps, websites, and AI automation for established small businesses across Springfield and Western Massachusetts. Manny turns the manual processes that slow a business down into software that runs them — from ecommerce stores and lead-to-job systems to data pipelines and API integrations.',
      url: siteUrl,
      email: EMAIL,
      telephone: PHONE_TEL,
      image: `${siteUrl}/favicon.svg`,
      priceRange: '$$',
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Springfield',
        addressRegion: 'MA',
        addressCountry: 'US',
      },
      areaServed: [
        { '@type': 'City', name: 'Springfield, Massachusetts' },
        { '@type': 'City', name: 'Chicopee, Massachusetts' },
        { '@type': 'City', name: 'Holyoke, Massachusetts' },
        { '@type': 'City', name: 'Westfield, Massachusetts' },
        { '@type': 'City', name: 'West Springfield, Massachusetts' },
        { '@type': 'City', name: 'Agawam, Massachusetts' },
        { '@type': 'City', name: 'Northampton, Massachusetts' },
        { '@type': 'City', name: 'Amherst, Massachusetts' },
        { '@type': 'AdministrativeArea', name: 'Pioneer Valley' },
        { '@type': 'AdministrativeArea', name: 'Hampden County, Massachusetts' },
        { '@type': 'AdministrativeArea', name: 'Western Massachusetts' },
      ],
      founder: { '@id': `${siteUrl}/#manny` },
      sameAs: [
        'https://www.linkedin.com/in/mrmanu/',
        'https://www.youtube.com/@MannyKnows-com/posts',
        'https://www.tiktok.com/@mannyknowsai',
      ],
    },
    {
      '@type': 'Person',
      '@id': `${siteUrl}/#manny`,
      name: 'Manny',
      jobTitle: 'Founder',
      worksFor: { '@id': `${siteUrl}/#business` },
      url: siteUrl,
      sameAs: ['https://www.linkedin.com/in/mrmanu/'],
      knowsAbout: [
        'Custom app & software development for small businesses',
        'Turning manual business processes into software',
        'Web development',
        'AI automation',
        'CRM development',
        'Local SEO',
        'Google Business Profile',
        'eCommerce development',
        'API integrations and data pipelines',
      ],
    },
    {
      '@type': 'WebSite',
      '@id': `${siteUrl}/#website`,
      url: siteUrl,
      name: 'MannyKnows',
      publisher: { '@id': `${siteUrl}/#business` },
      inLanguage: 'en-US',
    },
  ],
};
// ========================================
// NAVBAR CONFIGURATION
// ========================================
const NAVBAR_CONFIG = {
	// Search gradient animations in navbar
	searchGradientEnabled: true,
	searchScrollDelay: 0,
	
	// Debug mode for development
	debugMode: false,
};
---

<BaseLayout
	title="Web Design, SEO & AI for Western Massachusetts | MannyKnows"
	description="One-on-one web design, local SEO, and AI booking agents for small businesses across Western Massachusetts — fast sites that get found on Google and book jobs 24/7. Springfield, MA."
	footerServices={true}
	preconnect={['https://images.unsplash.com']}
>
	<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
	<main class="relative bg-light-primary dark:bg-dark-primary text-text-light-primary dark:text-text-dark-primary min-h-screen transition-colors duration-300">
		<!-- Marquee Announcement Section -->

		<!-- Header Container with Subtle Background -->
		<header class="relative bg-gradient-to-t from-gray-50/50 via-gray-100/30 to-gray-50/20 dark:from-gray-900/60 dark:via-slate-800/40 dark:to-gray-900/30 transition-colors duration-300">
            <!-- Navigation -->
            <NavBar
				animationConfig={{
					searchGradientEnabled: NAVBAR_CONFIG.searchGradientEnabled,
					debugMode: NAVBAR_CONFIG.debugMode,
					searchScrollDelay: NAVBAR_CONFIG.searchScrollDelay
				}}
			/>

            <!-- Hero stack: slider leads on mobile; follows the headline on desktop -->
            <div class="flex flex-col">
            <!-- Hero Section -->
            <HeroSection
                badge="Springfield · Western Massachusetts"
                title=""
                highlightedText="Websites, SEO, AI Agents & Apps"
                titleAfter=", done right"
                subtitle="Custom websites, local SEO, and AI booking agents for contractors, clinics, and small businesses across Western Massachusetts — built one-on-one with a senior engineer, not an agency."
            />

            <!-- Hero CTAs + credibility stat band -->
            <div class="max-w-[1440px] mx-auto px-4 mt-8 pb-10 md:pb-0">
              <div class="flex flex-row items-stretch justify-center gap-3 sm:gap-4">
                <Button href="/free-360-photo" text="FREE 360° PHOTO" subtext="CLAIM NOW" variant="theme-aware" sparkles={true} sparkleTheme="purple" className="flex-1 sm:flex-none sm:px-8" />
                <Button href="/free-ai-website-analysis" text="FREE AI WEBSITE" subtext="ANALYSIS" variant="emoji" emoji="🚀" emojiAnimation="subtle" sparkles={false} className="flex-1 sm:flex-none sm:px-8" />
              </div>
              <ul class="mt-8 grid grid-cols-2 gap-x-4 gap-y-5 sm:flex sm:flex-wrap sm:items-center sm:justify-center sm:gap-x-7 sm:gap-y-3 text-sm text-text-light-secondary dark:text-text-dark-secondary">
                <li class="flex flex-col items-center text-center gap-0.5 sm:flex-row sm:items-center sm:gap-2 sm:text-left"><span class="text-lg font-black apple-gradient-text whitespace-nowrap">Page 1</span> <span class="text-xs sm:text-sm">clients ranked on Google’s first page locally</span></li>
                <li class="flex flex-col items-center text-center gap-0.5 sm:flex-row sm:items-center sm:gap-2 sm:text-left"><span class="text-lg font-black apple-gradient-text">24/7</span> <span class="text-xs sm:text-sm">an AI agent that answers &amp; books jobs</span></li>
                <li class="flex flex-col items-center text-center gap-0.5 sm:flex-row sm:items-center sm:gap-2 sm:text-left"><span class="text-lg font-black apple-gradient-text">~100</span> <span class="text-xs sm:text-sm">Lighthouse speed on every build</span></li>
                <li class="flex flex-col items-center text-center gap-0.5 sm:flex-row sm:items-center sm:gap-2 sm:text-left"><span class="text-lg font-black apple-gradient-text whitespace-nowrap">1-on-1</span> <span class="text-xs sm:text-sm">a senior engineer, not an agency</span></li>
              </ul>
            </div>

            <!-- Hero Swiper Slider — first on mobile, last on desktop; mascot rides its lower-left corner -->
            <div class="relative order-first md:order-none">
              <HeroSwiper />
              <div class="astronaut-mascot" aria-hidden="true"></div>
            </div>
            </div>
        </header>

		<!-- Latest Work (real client sites) — portfolio proof, placed right after the hero -->
		<PageSection
			id="work"
			badge="Portfolio"
			title="Latest work"
			subtitle="Sites we've designed and built for real businesses. Click any for the full story."
			variant="alternate"
		>
			<SelectedWork />
		</PageSection>

		<!-- Testimonials — driven by src/data/testimonials.ts; renders NOTHING
		     while the real list is empty. Preview format: /preview/testimonials.
		     (Replaces the retired ReviewsSection carousel.) -->
		<Testimonials />

		<!-- Plans — monthly retainers, "starting at" pricing, tailored per client -->
		<PageSection
			id="plans"
			badge="Monthly plans"
			title="Plans that grow with you"
			subtitle="Monthly plans, scoped to your business. Start with what you need — a website, an online store, marketing, or a full tech team — and adjust anytime."
		>
			<PricingPlans />
		</PageSection>

		<!-- Idea Launchpad — bring an idea, we design, build & launch the app for you -->
		<PageSection
			id="launchpad"
			badge="Got an idea?"
			title="You bring the idea. We build the app."
			subtitle="No upfront cost to get started. We design, build, launch, and market it for you — and turn it into a real, working app."
		>
			<IdeaLaunchpad />
		</PageSection>

		<!-- "New Playbooks" (blog highlights) — moved here so it sits last, right above the footer. -->
		<BlogHighlights />

		<!-- Customer Reviews Section — hidden until a real client testimonial (e.g. SL Painting) is ready.
		     Fabricated testimonials were removed; see ReviewsSection.astro. -->
		<!-- <ReviewsSection /> -->

		<!-- Chat Box -->
		<ChatBox />

		<!-- Floating Dock Menu -->
		<DockMenu />
	</main>
</BaseLayout>

<script>
  // Handle URL parameters for chat opening and reference tracking
  document.addEventListener('DOMContentLoaded', () => {
    const urlParams = new URLSearchParams(window.location.search);
    const chatParam = urlParams.get('chat');
    const refParam = urlParams.get('ref');
    
    // Auto-open chat if ?chat=open parameter is present
    if (chatParam === 'open') {
      // Small delay to ensure ChatBox component is initialized
      setTimeout(() => {
        const chatToggle = document.getElementById('dockChatToggle') || 
                          document.getElementById('topChatToggle') || 
                          document.getElementById('heroChatButton');
        
        if (chatToggle) {
          chatToggle.click();
          
          // If there's a reference parameter, store it and trigger contextual greeting
          if (refParam) {
            try {
              sessionStorage.setItem('mk_chat_reference', refParam);
              console.log('📧 Chat opened with reference:', refParam);
              
              // Trigger contextual AI greeting after chat opens
              setTimeout(() => {
                const chatInput = document.getElementById('chatBoxInput');
                if (chatInput && (window as any).triggerContextualGreeting) {
                  (window as any).triggerContextualGreeting(refParam);
                }
              }, 1000);
            } catch (e) {
              console.warn('Could not store chat reference:', e);
            }
          }
        } else {
          console.warn('Chat toggle button not found');
        }
      }, 500);
    }
    
    // Clean up URL parameters after processing (optional - keeps URL clean)
    if (chatParam || refParam) {
      const cleanUrl = window.location.pathname;
      window.history.replaceState({}, document.title, cleanUrl);
    }
  });
</script>

<style>
  /* Brand astronaut mascot — anchored to the lower-left of the header (below the
     slider). CSS background-image so a missing file shows nothing until the PNG
     lands at public/art/astronaut-rocket.png. */
  .astronaut-mascot {
    position: absolute;
    bottom: 3rem;
    left: max(0.5rem, 1vw);
    width: clamp(110px, 30vw, 220px);
    aspect-ratio: 1 / 1;
    background: url('/art/astronaut-rocket.png') center / contain no-repeat;
    pointer-events: none;
    z-index: 20;
    filter: drop-shadow(0 14px 26px rgba(0, 0, 0, 0.16));
    animation: astronautFloat 5.4s ease-in-out infinite;
    will-change: transform;
  }
  @keyframes astronautFloat {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50%      { transform: translateY(-14px) rotate(3.3deg); }
  }
  @media (prefers-reduced-motion: reduce) {
    .astronaut-mascot { animation: none; }
  }
  /* Bigger on wide screens, still anchored to the slider's lower-left corner. */
  @media (min-width: 1024px) {
    .astronaut-mascot { width: clamp(150px, 18vw, 320px); bottom: 3.5rem; }
  }
</style>