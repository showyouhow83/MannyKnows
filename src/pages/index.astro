---
// Import the Layout component
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
import NavBar from '../components/navigation/NavBar.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import HeroSwiper from '../components/sections/HeroSwiper.astro';
// BlogHighlights ("New playbooks") is hidden from the homepage for now — re-enable
// the import and the <BlogHighlights /> tag below to bring it back.
// import BlogHighlights from '../components/sections/BlogHighlights.astro';
// Reviews section is temporarily hidden from the homepage until we have a real
// client testimonial to display. The fabricated testimonials were removed from
// Testimonials render from src/data/testimonials.ts — hidden while the real
// list is empty; add real quotes there to make the section appear.
import Testimonials from '../components/sections/Testimonials.astro';
import DockMenu from '../components/navigation/DockMenu.astro';
import PageSection from '../components/layout/PageSection.astro';
import SelectedWork from '../components/sections/SelectedWork.astro';
import HomeAiTeam from '../components/sections/HomeAiTeam.astro';
import HomeAbout from '../components/sections/HomeAbout.astro';
import PricingPlans from '../components/sections/PricingPlans.astro';
import ChatBox from '../components/ui/ChatBox.astro';

// ========================================
// LOCAL SEO — structured data (LocalBusiness / Person / WebSite)
// Real NAP, service area, and social profiles for Manny / MannyKnows.
// ========================================
const siteUrl = 'https://mannyknows.com';
const PHONE_TEL = '+14133618451';
const EMAIL = 'mm@mannyknows.com';

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'ProfessionalService',
      '@id': `${siteUrl}/#business`,
      name: 'MannyKnows',
      description:
        'Custom apps, websites, and AI automation for established small businesses across Springfield and Western Massachusetts. Manny turns the manual processes that slow a business down into software that runs them — from ecommerce stores and lead-to-job systems to data pipelines and API integrations.',
      url: siteUrl,
      email: EMAIL,
      telephone: PHONE_TEL,
      image: `${siteUrl}/favicon.svg`,
      priceRange: '$$',
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Springfield',
        addressRegion: 'MA',
        addressCountry: 'US',
      },
      areaServed: [
        { '@type': 'City', name: 'Springfield, Massachusetts' },
        { '@type': 'City', name: 'Chicopee, Massachusetts' },
        { '@type': 'City', name: 'Holyoke, Massachusetts' },
        { '@type': 'City', name: 'Westfield, Massachusetts' },
        { '@type': 'City', name: 'West Springfield, Massachusetts' },
        { '@type': 'City', name: 'Agawam, Massachusetts' },
        { '@type': 'City', name: 'Northampton, Massachusetts' },
        { '@type': 'City', name: 'Amherst, Massachusetts' },
        { '@type': 'City', name: 'Longmeadow, Massachusetts' },
        { '@type': 'City', name: 'East Longmeadow, Massachusetts' },
        { '@type': 'City', name: 'Wilbraham, Massachusetts' },
        { '@type': 'City', name: 'Monson, Massachusetts' },
        { '@type': 'City', name: 'Greenfield, Massachusetts' },
        { '@type': 'City', name: 'Deerfield, Massachusetts' },
        { '@type': 'City', name: 'Ludlow, Massachusetts' },
        { '@type': 'City', name: 'Hampden, Massachusetts' },
        { '@type': 'City', name: 'Enfield, Connecticut' },
        { '@type': 'City', name: 'Suffield, Connecticut' },
        { '@type': 'City', name: 'Windsor Locks, Connecticut' },
        { '@type': 'City', name: 'Granby, Connecticut' },
        { '@type': 'City', name: 'Somers, Connecticut' },
        { '@type': 'AdministrativeArea', name: 'Pioneer Valley' },
        { '@type': 'AdministrativeArea', name: 'Hampden County, Massachusetts' },
        { '@type': 'AdministrativeArea', name: 'Western Massachusetts' },
      ],
      sameAs: [
        'https://www.linkedin.com/in/mr83/',
        'https://www.youtube.com/@MannyKnows-com/posts',
        'https://www.tiktok.com/@mannyknowsai',
      ],
      hasOfferCatalog: {
        '@type': 'OfferCatalog',
        name: 'Services',
        itemListElement: [
          {
            '@type': 'Offer',
            priceCurrency: 'USD',
            priceSpecification: { '@type': 'UnitPriceSpecification', price: '349', priceCurrency: 'USD', unitText: 'MONTH' },
            itemOffered: { '@type': 'Service', name: 'AI Smart Website (bilingual web design)', description: 'A multilingual website with a built-in AI agent that answers, books, and sells, on Cloudflare’s edge network.' },
          },
          {
            '@type': 'Offer',
            priceCurrency: 'USD',
            priceSpecification: { '@type': 'UnitPriceSpecification', price: '99', priceCurrency: 'USD', unitText: 'MONTH' },
            itemOffered: { '@type': 'Service', name: 'AI Team (AI agents)', description: 'AI agents hired per role — sales & booking, research, copy, graphics, voice, SEO, publishing, ads, engagement, and reporting.' },
          },
          {
            '@type': 'Offer',
            itemOffered: { '@type': 'Service', name: 'Local SEO', description: 'Local map-pack visibility, Google Business Profile, and technical SEO for Western Massachusetts businesses.' },
          },
        ],
      },
    },
    {
      '@type': 'WebSite',
      '@id': `${siteUrl}/#website`,
      url: siteUrl,
      name: 'MannyKnows',
      publisher: { '@id': `${siteUrl}/#business` },
      inLanguage: 'en-US',
    },
  ],
};
// ========================================
// NAVBAR CONFIGURATION
// ========================================
const NAVBAR_CONFIG = {
	// Search gradient animations in navbar
	searchGradientEnabled: true,
	searchScrollDelay: 0,
	
	// Debug mode for development
	debugMode: false,
};
---

<BaseLayout
	title="Web Design, SEO & AI Agency in Springfield & Western Mass | MannyKnows"
	description="Bilingual websites, AI agents from $99/mo, and local SEO — built in Springfield, MA. Cancel anytime. Serving all of Western Mass. Call or text (413) 361-8451."
	footerServices={true}
	preconnect={['https://images.unsplash.com']}
>
	<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
	<main class="relative bg-light-primary dark:bg-dark-primary text-text-light-primary dark:text-text-dark-primary min-h-screen transition-colors duration-300">
		<!-- Marquee Announcement Section -->

		<!-- Header Container with Subtle Background -->
		<header class="relative bg-gradient-to-t from-gray-50/50 via-gray-100/30 to-gray-50/20 dark:from-gray-900/60 dark:via-slate-800/40 dark:to-gray-900/30 transition-colors duration-300">
            <!-- Navigation -->
            <NavBar
				animationConfig={{
					searchGradientEnabled: NAVBAR_CONFIG.searchGradientEnabled,
					debugMode: NAVBAR_CONFIG.debugMode,
					searchScrollDelay: NAVBAR_CONFIG.searchScrollDelay
				}}
			/>

            <!-- Hero stack: slider leads on mobile; follows the headline on desktop -->
            <div class="flex flex-col">
            <!-- Hero Section -->
            <HeroSection
                badge="Springfield · Western Massachusetts"
                title=""
                highlightedText="AI Agents, Websites, SEO & Apps"
                titleAfter=""
                subtitle="Web design, SEO, and AI agency based in Springfield, Massachusetts, built for small and local businesses across Western Mass. We build your custom website, get you ranking on Google and the AI answer engines your customers are asking instead, then set you up with AI agents that write, answer calls, support customers, and close sales — 24/7, under your name, with your final say."
            />

            <!-- Trust/positioning line under the subhead -->
            <p class="sf-regular text-sm sm:text-base text-text-light-tertiary dark:text-text-dark-tertiary max-w-3xl mx-auto mt-4 px-4 text-center apple-body-text">
              Twenty years of enterprise experience, scaled down to Western Mass budgets. No agency bloat, no corporate jargon — just results.
            </p>

            <!-- Hero CTAs + credibility stat band -->
            <div class="max-w-[1440px] mx-auto px-4 mt-8 pb-10 md:pb-16">
              <div class="flex flex-row items-stretch justify-center gap-3 sm:gap-4 max-w-md sm:max-w-none mx-auto">
                <Button href="/free-360-photo" text="FREE 360° PHOTO" subtext="CLAIM NOW" variant="theme-aware" sparkles={true} sparkleTheme="purple" className="flex-1 sm:flex-none sm:px-8" />
                <Button href="/free-ai-website-analysis" text="FREE AI WEBSITE" subtext="ANALYSIS" variant="emoji" emoji="🚀" emojiAnimation="subtle" sparkles={false} className="flex-1 sm:flex-none sm:px-8" />
              </div>
              <ul class="mt-8 grid grid-cols-3 gap-x-2 gap-y-6 sm:gap-x-4 md:gap-x-5 max-w-3xl mx-auto text-text-light-secondary dark:text-text-dark-secondary">
                <li class="flex flex-col items-center text-center gap-1"><span class="text-base sm:text-lg font-black apple-gradient-text whitespace-nowrap">Rank #1</span> <span class="text-xs leading-snug">on Google’s 1st page organically</span></li>
                <li class="flex flex-col items-center text-center gap-1"><span class="text-base sm:text-lg font-black apple-gradient-text">24/7 AI-driven</span> <span class="text-xs leading-snug">smart website, engages and supports visitors</span></li>
                <li class="flex flex-col items-center text-center gap-1"><span class="text-base sm:text-lg font-black apple-gradient-text whitespace-nowrap">1-on-1</span> <span class="text-xs leading-snug">a dedicated senior pro in every project</span></li>
              </ul>
            </div>

            <!-- Hero Swiper Slider — leads on both mobile & desktop; mascot rides its lower-left corner -->
            <div class="relative order-first">
              <HeroSwiper />
            </div>
            </div>
        </header>

		<!-- AI Team — the flagship; teaser that routes to the /ai-team lander -->
		<PageSection
			id="ai-team"
			badge="AI Team"
			title="Your AI team, ready to hire"
			subtitle="Hire AI agents the way you'd hire staff — each built around your business and trained on your brand, then run on demand from a simple admin, with you approving what goes out."
			variant="alternate"
		>
			<HomeAiTeam />
		</PageSection>

		<!-- Plans ("Plans that grow with you") — hidden from the homepage per request
		     (kept, not deleted, in case we want it back). The plans still live on the
		     dedicated /plans page. -->
		{/*
		<PageSection
			id="plans"
			badge="Monthly plans"
			title="Plans that grow with you"
			subtitle="Monthly plans, scoped to your business. Start with what you need — a website, an online store, marketing, or a full tech team — and adjust anytime."
			variant="alternate"
		>
			<PricingPlans />
		</PageSection>
		*/}

		<!-- Latest Work (real client sites) — portfolio proof, placed right after the hero -->
		<PageSection
			id="work"
			badge="Portfolio"
			title="Latest projects"
			subtitle="Sites we've designed and built for real businesses. Click any for the full story."
			variant="alternate"
		>
			<SelectedWork />
		</PageSection>

		<!-- Who you're working with — condensed founder intro, routes to /about -->
		<PageSection
			id="about"
			badge="Your solutions partner"
			title="Who you're working with"
			variant="default"
		>
			<HomeAbout />
		</PageSection>

		<!-- Testimonials — driven by src/data/testimonials.ts; renders NOTHING
		     while the real list is empty. Preview format: /preview/testimonials.
		     (Replaces the retired ReviewsSection carousel.) -->
		<Testimonials />

		<!-- "New Playbooks" (blog highlights) — hidden from the homepage per request
		     (kept, not deleted, in case we want it back). The posts still live in the
		     footer's "AI News" column and at /blog. -->
		{/* <BlogHighlights /> */}

		<!-- Customer Reviews Section — hidden until a real client testimonial (e.g. SL Painting) is ready.
		     Fabricated testimonials were removed; see ReviewsSection.astro. -->
		<!-- <ReviewsSection /> -->

		<!-- Chat Box -->
		<ChatBox />

		<!-- Floating Dock Menu -->
		<DockMenu />
	</main>
</BaseLayout>

<script>
  // Handle URL parameters for chat opening and reference tracking
  document.addEventListener('DOMContentLoaded', () => {
    const urlParams = new URLSearchParams(window.location.search);
    const chatParam = urlParams.get('chat');
    const refParam = urlParams.get('ref');
    
    // Auto-open chat if ?chat=open parameter is present
    if (chatParam === 'open') {
      // Small delay to ensure ChatBox component is initialized
      setTimeout(() => {
        const chatToggle = document.getElementById('dockChatToggle') || 
                          document.getElementById('topChatToggle') || 
                          document.getElementById('heroChatButton');
        
        if (chatToggle) {
          chatToggle.click();
          
          // If there's a reference parameter, store it and trigger contextual greeting
          if (refParam) {
            try {
              sessionStorage.setItem('mk_chat_reference', refParam);
              console.log('📧 Chat opened with reference:', refParam);
              
              // Trigger contextual AI greeting after chat opens
              setTimeout(() => {
                const chatInput = document.getElementById('chatBoxInput');
                if (chatInput && (window as any).triggerContextualGreeting) {
                  (window as any).triggerContextualGreeting(refParam);
                }
              }, 1000);
            } catch (e) {
              console.warn('Could not store chat reference:', e);
            }
          }
        } else {
          console.warn('Chat toggle button not found');
        }
      }, 500);
    }
    
    // Clean up URL parameters after processing (optional - keeps URL clean)
    if (chatParam || refParam) {
      const cleanUrl = window.location.pathname;
      window.history.replaceState({}, document.title, cleanUrl);
    }
  });
</script>

