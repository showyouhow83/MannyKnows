---
// Individual case study — a client or capability project with the full story.
// Data: src/content/portfolio/*.md (schema in src/content.config.ts).
export const prerender = true;

import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import NavBar from '../../components/navigation/NavBar.astro';
import Section from '../../components/layout/Section.astro';
import Container from '../../components/layout/Container.astro';
import DockMenu from '../../components/navigation/DockMenu.astro';
import ChatBox from '../../components/ui/ChatBox.astro';
import Button from '../../components/ui/Button.astro';
import QuoteBlock from '../../components/ui/QuoteBlock.astro';
import { getTestimonial } from '../../data/testimonials';

export async function getStaticPaths() {
  const projects = await getCollection('portfolio');
  return projects
    .filter((p) => !p.data.draft)
    .map((project) => ({ params: { slug: project.id }, props: { project } }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const d = project.data;

// This client's own testimonial, if they've given one (undefined otherwise).
const clientQuote = getTestimonial(d.client ?? d.title);

// Responsive screenshots share the homepage pipeline: variants live at
// public/works/<base>-<width>.<ext>. A value containing "/" or "." is treated
// as a literal src/URL instead (e.g. "/works/foo.png" or an external image).
const IMG_WIDTHS = [400, 640, 960, 1280];
const isLiteral = (v: string) => v.includes('/') || v.includes('.');
const srcset = (base: string, ext: 'avif' | 'webp') =>
  IMG_WIDTHS.map((w) => `/works/${base}-${w}.${ext} ${w}w`).join(', ');
const fallbackSrc = (base: string) => `/works/${base}-960.webp`;

const host = (url: string) => url.replace(/^https?:\/\//, '').replace(/\/+$/, '');

// Compact "at a glance" rows — only render the ones that have data.
const facts = [
  d.role && { label: 'What we did', value: d.role },
  d.industry && { label: 'Industry', value: d.industry },
  d.timeline && { label: 'Timeline', value: d.timeline },
  d.year && { label: 'Year', value: String(d.year) },
].filter(Boolean) as { label: string; value: string }[];
---

<BaseLayout
  title={`${d.title} — Case Study | MannyKnows`}
  description={d.summary}
  image={d.heroImage && isLiteral(d.heroImage) ? d.heroImage : undefined}
>
  <main class="relative bg-light-primary dark:bg-dark-primary text-text-light-primary dark:text-text-dark-primary min-h-screen transition-colors duration-300">

    <header class="relative bg-gradient-to-t from-gray-50/50 via-gray-100/30 to-gray-50/20 dark:from-gray-900/60 dark:via-slate-800/40 dark:to-gray-900/30 transition-colors duration-300">
      <NavBar />
      <nav aria-label="breadcrumb" class="max-w-[1440px] mx-auto px-4 lg:px-6 pt-24 pb-4">
        <ol class="flex flex-wrap items-center gap-2 text-sm text-text-light-secondary dark:text-text-dark-secondary">
          <li><a href="/" class="hover:text-primary-blue transition-colors">Home</a></li>
          <li class="flex items-center"><span class="mx-2 text-text-light-tertiary dark:text-text-dark-tertiary">/</span><a href="/work" class="hover:text-primary-blue transition-colors">Work</a></li>
          <li class="flex items-center"><span class="mx-2 text-text-light-tertiary dark:text-text-dark-tertiary">/</span><span class="text-text-light-primary dark:text-text-dark-primary font-medium truncate max-w-[40ch]">{d.title}</span></li>
        </ol>
      </nav>
      <div class="pb-10 px-4">
        <Container>
          <div class="max-w-3xl mx-auto">
            <span class="inline-block text-[11px] font-bold uppercase tracking-wide px-2.5 py-1 rounded-full mb-4 bg-primary-blue/15 text-primary-blue dark:text-blue-300">Case Study</span>
            <h1 class="sf-bold apple-headline text-3xl md:text-4xl lg:text-5xl mb-5 leading-tight">
              <span class="apple-gradient-text" data-colorful-title>{d.title}</span>
            </h1>
            <p class="text-lg md:text-xl text-text-light-primary dark:text-text-dark-primary font-medium mb-3 leading-snug">{d.tagline}</p>
            <p class="text-base text-text-light-secondary dark:text-text-dark-secondary leading-relaxed mb-6">{d.summary}</p>
            <div class="flex flex-col sm:flex-row gap-4">
              <Button href="#contact" text="Start a project like this" variant="cta" arrow={true} />
              {d.liveUrl && (
                <a href={d.liveUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 px-6 h-12 rounded-full border border-light-tertiary dark:border-dark-accent text-text-light-primary dark:text-text-dark-primary font-medium hover:border-primary-blue/40 transition-colors">
                  Visit live site
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                </a>
              )}
            </div>
          </div>
        </Container>
      </div>
    </header>

    <Section id="case-study" variant="default">
      <Container>
        <div class="max-w-5xl mx-auto">
          {d.heroImage && (
            <div class="rounded-2xl overflow-hidden border border-light-tertiary dark:border-dark-accent mb-12 aspect-[16/9] shadow-sm">
              {isLiteral(d.heroImage) ? (
                <img src={d.heroImage} alt={d.title} width="1280" height="720" loading="eager" decoding="async" class="w-full h-full object-cover" />
              ) : (
                <picture>
                  <source type="image/avif" srcset={srcset(d.heroImage, 'avif')} sizes="(min-width: 1024px) 960px, 92vw" />
                  <source type="image/webp" srcset={srcset(d.heroImage, 'webp')} sizes="(min-width: 1024px) 960px, 92vw" />
                  <img src={fallbackSrc(d.heroImage)} alt={d.title} width="1280" height="720" loading="eager" decoding="async" class="w-full h-full object-cover" />
                </picture>
              )}
            </div>
          )}

          <div class="grid lg:grid-cols-[1fr_18rem] gap-10 lg:gap-14 items-start">
            <!-- Narrative + goals + results -->
            <div class="order-2 lg:order-1 min-w-0">
              {d.results.length > 0 && (
                <div class={`grid gap-4 mb-12 ${d.results.length >= 3 ? 'sm:grid-cols-3' : 'sm:grid-cols-2'}`}>
                  {d.results.map((r) => (
                    <div class="rounded-2xl border border-light-tertiary dark:border-dark-accent bg-white/60 dark:bg-dark-secondary/60 p-5 text-center">
                      <div class="text-3xl md:text-4xl font-bold apple-gradient-text leading-none mb-2">{r.value}</div>
                      <div class="text-xs text-text-light-secondary dark:text-text-dark-secondary uppercase tracking-wide">{r.label}</div>
                    </div>
                  ))}
                </div>
              )}

              {d.goals.length > 0 && (
                <div class="mb-12">
                  <h2 class="text-xl font-bold text-text-light-primary dark:text-text-dark-primary mb-4">Goals</h2>
                  <ul class="space-y-3">
                    {d.goals.map((g) => (
                      <li class="flex items-start gap-3 text-text-light-primary dark:text-text-dark-primary">
                        <svg class="w-5 h-5 text-primary-blue flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4"/></svg>
                        <span class="leading-relaxed">{g}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              )}

              <article class="blog-prose">
                <Content />
              </article>

              {clientQuote && <div class="mt-8"><QuoteBlock quote={clientQuote} /></div>}
            </div>

            <!-- "At a glance" sticky sidebar -->
            <aside class="order-1 lg:order-2 lg:sticky lg:top-24">
              <div class="rounded-2xl border border-light-tertiary dark:border-dark-accent bg-white/60 dark:bg-dark-secondary/60 p-6">
                <h2 class="text-xs font-bold uppercase tracking-wide text-text-light-tertiary dark:text-text-dark-tertiary mb-4">At a glance</h2>
                <dl class="space-y-4">
                  {facts.map((f) => (
                    <div>
                      <dt class="text-xs text-text-light-tertiary dark:text-text-dark-tertiary mb-0.5">{f.label}</dt>
                      <dd class="text-sm font-medium text-text-light-primary dark:text-text-dark-primary">{f.value}</dd>
                    </div>
                  ))}
                </dl>

                {d.services.length > 0 && (
                  <div class="mt-5 pt-5 border-t border-light-tertiary dark:border-dark-accent">
                    <div class="text-xs text-text-light-tertiary dark:text-text-dark-tertiary mb-2">Delivered</div>
                    <ul class="space-y-2">
                      {d.services.map((s) => (
                        <li class="flex items-start gap-2 text-sm text-text-light-primary dark:text-text-dark-primary">
                          <svg class="w-4 h-4 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                          <span>{s}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                )}

                {d.techStack.length > 0 && (
                  <div class="mt-5 pt-5 border-t border-light-tertiary dark:border-dark-accent">
                    <div class="text-xs text-text-light-tertiary dark:text-text-dark-tertiary mb-2">Tech stack</div>
                    <div class="flex flex-wrap gap-1.5">
                      {d.techStack.map((t) => (
                        <span class="text-[11px] font-medium text-primary-blue dark:text-blue-300 bg-primary-blue/10 rounded-full px-2 py-0.5">{t}</span>
                      ))}
                    </div>
                  </div>
                )}

                {d.liveUrl && (
                  <a href={d.liveUrl} target="_blank" rel="noopener noreferrer" class="mt-5 pt-5 border-t border-light-tertiary dark:border-dark-accent flex items-center gap-2 text-sm text-primary-blue font-medium hover:underline">
                    {host(d.liveUrl)}
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H8M17 7v9"/></svg>
                  </a>
                )}
              </div>
            </aside>
          </div>

          {d.gallery.length > 0 && (
            <div class="mt-14 grid gap-5 sm:grid-cols-2">
              {d.gallery.map((g) => (
                <div class="rounded-2xl overflow-hidden border border-light-tertiary dark:border-dark-accent aspect-[16/9]">
                  {isLiteral(g) ? (
                    <img src={g} alt={`${d.title} screenshot`} loading="lazy" decoding="async" class="w-full h-full object-cover" />
                  ) : (
                    <picture>
                      <source type="image/avif" srcset={srcset(g, 'avif')} sizes="(min-width: 640px) 45vw, 92vw" />
                      <source type="image/webp" srcset={srcset(g, 'webp')} sizes="(min-width: 640px) 45vw, 92vw" />
                      <img src={fallbackSrc(g)} alt={`${d.title} screenshot`} width="1280" height="720" loading="lazy" decoding="async" class="w-full h-full object-cover" />
                    </picture>
                  )}
                </div>
              ))}
            </div>
          )}

          <div class="mt-14 pt-8 border-t border-light-tertiary dark:border-dark-accent flex items-center justify-between flex-wrap gap-4">
            <a href="/work" class="inline-flex items-center gap-2 text-primary-blue font-medium group">
              <svg class="w-4 h-4 rotate-180 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              All work
            </a>
            <Button href="#contact" text="Get started" variant="cta" arrow={true} />
          </div>
        </div>
      </Container>
    </Section>

    <ChatBox />
    <DockMenu />
  </main>
</BaseLayout>

<style>
  .blog-prose { color: inherit; font-size: 1.075rem; line-height: 1.8; }
  .blog-prose :global(h2) { font-size: 1.6rem; font-weight: 700; margin: 2.25rem 0 0.75rem; line-height: 1.3; }
  .blog-prose :global(h3) { font-size: 1.25rem; font-weight: 700; margin: 1.75rem 0 0.5rem; }
  .blog-prose :global(p) { margin: 0 0 1.25rem; }
  .blog-prose :global(ul), .blog-prose :global(ol) { margin: 0 0 1.25rem; padding-left: 1.5rem; }
  .blog-prose :global(li) { margin: 0.4rem 0; }
  .blog-prose :global(ul) { list-style: disc; }
  .blog-prose :global(ol) { list-style: decimal; }
  .blog-prose :global(a) { color: #0071e3; text-decoration: underline; text-underline-offset: 2px; }
  .blog-prose :global(a:hover) { color: #ff4faa; }
  .blog-prose :global(strong) { font-weight: 700; }
  .blog-prose :global(blockquote) { border-left: 3px solid #0071e3; padding-left: 1rem; margin: 1.5rem 0; font-style: italic; opacity: 0.9; }
  .blog-prose :global(code) { background: rgba(127,127,127,0.15); padding: 0.15em 0.4em; border-radius: 4px; font-size: 0.9em; }
</style>
