---
// Services — the "start here" map. Everything MannyKnows does is a service;
// visitors only choose HOW they work with us: monthly (we run it) or one-time
// (a project they own). Routes to Plans, AI Team, and Projects.
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import NavBar from '../components/navigation/NavBar.astro';
import Section from '../components/layout/Section.astro';
import Container from '../components/layout/Container.astro';
import DockMenu from '../components/navigation/DockMenu.astro';
import ChatBox from '../components/ui/ChatBox.astro';
import Button from '../components/ui/Button.astro';
import AiWebsiteShowcase from '../components/sections/AiWebsiteShowcase.astro';
import QuoteBlock from '../components/ui/QuoteBlock.astro';
import { getTestimonial } from '../data/testimonials';

// The three ways to start — two monthly, one one-time.
const offerings = [
  {
    href: '/plans',
    tag: 'Monthly',
    title: 'Monthly Plans',
    desc: 'We build it and run it — a website, an online store, ads, or the whole package — kept fast, found, and up to date every month.',
    price: 'From $350/mo',
    icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z',
  },
  {
    href: '/ai-team',
    tag: 'Monthly',
    title: 'AI Team',
    desc: 'Hire AI agents like staff — sales & booking, research, copy, graphics & video, voice, publishing, and reviews — built around your business and run on demand from your admin.',
    price: '$199 setup · agents from $99/mo',
    icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z',
  },
  {
    href: '/products',
    tag: 'One-time',
    title: 'Projects',
    desc: 'A fixed-scope job with a finish line — an audit, a website build, a technical-SEO push, an automation. You own the result.',
    price: 'Flat $75/hr · quoted up front',
    icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z',
  },
];
---

<BaseLayout
  title="Services — how we work with Western Mass businesses | MannyKnows"
  description="Everything MannyKnows does, in one place. Work with us two ways: monthly plans we run and AI agents you run on demand, or one-time projects you own. Websites, SEO for Google and AI search, AI agents, online stores, and ads for Western Massachusetts."
>
  <main class="relative bg-light-primary dark:bg-dark-primary text-text-light-primary dark:text-text-dark-primary min-h-screen transition-colors duration-300">

    <header class="relative bg-gradient-to-t from-gray-50/50 via-gray-100/30 to-gray-50/20 dark:from-gray-900/60 dark:via-slate-800/40 dark:to-gray-900/30 transition-colors duration-300">
      <NavBar />
      <nav aria-label="breadcrumb" class="max-w-[1440px] mx-auto px-4 lg:px-6 pt-6 pb-4">
        <ol class="flex flex-wrap items-center gap-2 text-sm text-text-light-secondary dark:text-text-dark-secondary">
          <li><a href="/" class="hover:text-primary-blue transition-colors">Home</a></li>
          <li class="flex items-center"><span class="mx-2 text-text-light-tertiary dark:text-text-dark-tertiary">/</span><span class="text-text-light-primary dark:text-text-dark-primary font-medium">Services</span></li>
        </ol>
      </nav>
      <div class="pb-12 px-4">
        <div class="max-w-3xl mx-auto text-center">
          <span class="inline-block bg-gradient-to-r from-primary-blue/10 via-purple-500/10 to-primary-pink/10 text-primary-blue px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider mb-4">Websites · SEO · AI · Stores · Ads</span>
          <h1 class="sf-bold apple-headline text-4xl md:text-5xl lg:text-6xl mb-6">
            <span class="apple-gradient-text" data-colorful-title>Everything we do — and how to start</span>
          </h1>
          <p class="text-base sm:text-xl text-text-light-secondary dark:text-text-dark-secondary leading-relaxed">
            It's all one thing: we make your business work online. You only choose <strong class="text-text-light-primary dark:text-text-dark-primary">how</strong> you want to work with us — a <strong class="text-text-light-primary dark:text-text-dark-primary">monthly</strong> arrangement we stay hands-on with, or a <strong class="text-text-light-primary dark:text-text-dark-primary">one-time project</strong> you own.
          </p>
        </div>
      </div>
    </header>

    <!-- Two ways to work -->
    <Section id="two-ways" variant="default">
      <Container>
        <div class="grid gap-6 md:grid-cols-2 max-w-4xl mx-auto">
          <div class="rounded-2xl border border-primary-blue/30 bg-primary-blue/[0.04] p-7">
            <span class="inline-block text-[11px] font-bold uppercase tracking-wide px-2.5 py-1 rounded-full mb-3 bg-primary-blue/15 text-primary-blue dark:text-blue-300">Monthly</span>
            <h2 class="text-xl font-bold text-text-light-primary dark:text-text-dark-primary mb-2">We stay in it with you</h2>
            <p class="text-sm text-text-light-secondary dark:text-text-dark-secondary leading-relaxed">Ongoing, month to month. With <a href="/plans" class="text-primary-blue dark:text-blue-300 hover:underline">Plans</a> we run your site and marketing end to end; with the <a href="/ai-team" class="text-primary-blue dark:text-blue-300 hover:underline">AI Team</a> we build and support the agents while <strong class="text-text-light-primary dark:text-text-dark-primary">you</strong> run them on demand. Best when you want it handled long-term, not just delivered once.</p>
          </div>
          <div class="rounded-2xl border border-light-tertiary dark:border-dark-accent bg-white/60 dark:bg-dark-secondary/60 p-7">
            <span class="inline-block text-[11px] font-bold uppercase tracking-wide px-2.5 py-1 rounded-full mb-3 bg-gray-500/10 text-text-light-secondary dark:text-text-dark-secondary">One-time</span>
            <h2 class="text-xl font-bold text-text-light-primary dark:text-text-dark-primary mb-2">You own the result</h2>
            <p class="text-sm text-text-light-secondary dark:text-text-dark-secondary leading-relaxed">A single job with a clear finish line — an audit, a build, an SEO push, an automation. Best when you want a <strong class="text-text-light-primary dark:text-text-dark-primary">specific thing done, once</strong>. That's a <a href="/products" class="text-primary-blue dark:text-blue-300 hover:underline">Project</a>. Many clients do a project first, then roll onto a plan.</p>
          </div>
        </div>
      </Container>
    </Section>

    <!-- Pick your starting point -->
    <Section id="offerings" variant="alternate">
      <Container>
        <div class="text-center max-w-2xl mx-auto mb-12">
          <h2 class="sf-bold text-2xl md:text-3xl font-bold">
            <span class="apple-gradient-text" data-colorful-title>Pick your starting point</span>
          </h2>
        </div>
        <div class="grid gap-6 md:grid-cols-3 max-w-5xl mx-auto">
          {offerings.map((o) => (
            <a href={o.href} class="group flex flex-col rounded-2xl border border-light-tertiary dark:border-dark-accent bg-white dark:bg-dark-secondary p-6 transition-all duration-300 hover:-translate-y-1 hover:border-primary-blue/40 hover:shadow-xl hover:shadow-primary-blue/10">
              <div class="flex items-center justify-between mb-4">
                <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-primary-blue to-primary-pink text-white shadow-lg shadow-primary-blue/20">
                  <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d={o.icon} /></svg>
                </div>
                <span class={`text-[11px] font-bold uppercase tracking-wide px-2.5 py-1 rounded-full ${o.tag === 'Monthly' ? 'bg-primary-blue/15 text-primary-blue dark:text-blue-300' : 'bg-gray-500/10 text-text-light-secondary dark:text-text-dark-secondary'}`}>{o.tag}</span>
              </div>
              <h3 class="text-lg font-bold text-text-light-primary dark:text-text-dark-primary">{o.title}</h3>
              <p class="mt-2 text-sm text-text-light-secondary dark:text-text-dark-secondary leading-relaxed flex-1">{o.desc}</p>
              <div class="mt-4 text-sm font-semibold text-text-light-primary dark:text-text-dark-primary">{o.price}</div>
              <span class="mt-3 inline-flex items-center gap-1.5 text-sm font-semibold text-primary-blue dark:text-blue-300">
                Explore
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
              </span>
            </a>
          ))}
        </div>
      </Container>
    </Section>

    <!-- Flagship demo: the AI website in action -->
    <section class="relative py-16 bg-light-primary dark:bg-dark-primary transition-colors duration-300 overflow-hidden">
      <div class="max-w-[1440px] mx-auto px-6 lg:px-8">
        <AiWebsiteShowcase />
        <div class="max-w-2xl mx-auto mt-16">
          <QuoteBlock quote={getTestimonial('SL Painting')} align="center" />
        </div>
        <div class="text-center mt-12">
          <Button href="#contact" text="Not sure which fits? Let's talk" variant="cta" arrow={true} />
        </div>
      </div>
    </section>

    <ChatBox />
    <DockMenu />
  </main>
</BaseLayout>
