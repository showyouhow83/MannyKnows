---
// The AI Team — our flagship, productized service. A named team of AI agents we
// build and run for your business, billed as a monthly retainer. Content is
// driven by src/data/aiTeam.ts.
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import NavBar from '../components/navigation/NavBar.astro';
import Section from '../components/layout/Section.astro';
import Container from '../components/layout/Container.astro';
import DockMenu from '../components/navigation/DockMenu.astro';
import ChatBox from '../components/ui/ChatBox.astro';
import AgentAvatar from '../components/team/AgentAvatar.astro';
import { team, aiTeamBundle, aiTeamSetupFee, aiTeamStartingPrice, aiTeamFaq } from '../data/aiTeam';
import { BOOKING_URL } from '../data/booking';

const roster = [...team].sort((a, b) => a.order - b.order);
const startFrom = aiTeamStartingPrice.toLocaleString('en-US');
const setup = aiTeamSetupFee.toLocaleString('en-US');
const bundleMo = aiTeamBundle.monthly.toLocaleString('en-US');
const alaCarte = aiTeamBundle.alaCarteTotal.toLocaleString('en-US');
const bundleSave = aiTeamBundle.savings.toLocaleString('en-US');

const steps = [
  { n: '01', title: 'A short kickoff call', body: "We learn your business — what you sell, who buys, and how you sound. That's all we need to start building the team.", icon: 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.9 9.9 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z' },
  { n: '02', title: 'We build & train the team', body: 'We set up each agent, train them on your brand, and connect the tools they need. You see the output before anything goes public.', icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z' },
  { n: '03', title: 'They work, you approve', body: 'The team researches, writes, designs, voices, publishes, and watches your reviews. You approve what matters and hand off the routine.', icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z' },
  { n: '04', title: 'We tune it every month', body: 'We watch what lands, adjust what does not, and send you a plain-English report. The team gets sharper the longer it runs.', icon: 'M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: aiTeamFaq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout
  title="The AI Team — hire AI agents like staff, built & run for you | MannyKnows"
  description="Hire AI agents the way you'd hire staff: a $199 one-time setup, then a flat monthly rate per agent (from $99/mo) — research, copywriting, design, video, voice, publishing, and reviews, with a human in the loop."
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <main class="relative bg-light-primary dark:bg-dark-primary text-text-light-primary dark:text-text-dark-primary min-h-screen transition-colors duration-300">

    <header class="relative bg-gradient-to-t from-gray-50/50 via-gray-100/30 to-gray-50/20 dark:from-gray-900/60 dark:via-slate-800/40 dark:to-gray-900/30 transition-colors duration-300">
      <NavBar />
      <nav aria-label="breadcrumb" class="max-w-[1440px] mx-auto px-4 lg:px-6 pt-24 pb-4">
        <ol class="flex flex-wrap items-center gap-2 text-sm text-text-light-secondary dark:text-text-dark-secondary">
          <li><a href="/" class="hover:text-primary-blue transition-colors">Home</a></li>
          <li class="flex items-center"><span class="mx-2 text-text-light-tertiary dark:text-text-dark-tertiary">/</span><span class="text-text-light-primary dark:text-text-dark-primary font-medium">AI Team</span></li>
        </ol>
      </nav>

      <div class="pb-12 px-4">
        <Container>
          <div class="max-w-3xl mx-auto text-center">
            <span class="inline-block bg-gradient-to-r from-primary-blue/10 via-purple-500/10 to-primary-pink/10 text-primary-blue px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider mb-4">
              The AI Team · live now
            </span>
            <h1 class="sf-bold apple-headline text-4xl md:text-5xl lg:text-6xl mb-6">
              <span class="apple-gradient-text" data-colorful-title>Your AI team, built and run for you</span>
            </h1>
            <p class="text-base sm:text-xl text-text-light-secondary dark:text-text-dark-secondary leading-relaxed">
              A team of AI specialists that keeps your marketing and your reputation running. We build it around your business, train it on your brand, and run it for you every month — with a real person watching the output. You keep doing what you do best.
            </p>

            <!-- Mini roster preview -->
            <div class="mt-8 flex items-center justify-center -space-x-2">
              {roster.map((a) => (
                <div class="w-11 h-11 sm:w-12 sm:h-12 rounded-full ring-2 ring-white dark:ring-dark-primary" title={`${a.name} — ${a.role}`}>
                  <AgentAvatar agent={a.id} class="w-full h-full" />
                </div>
              ))}
            </div>
            <p class="mt-3 text-xs text-text-light-tertiary dark:text-text-dark-tertiary">Six agents, one coordinated team — meet them below.</p>

            <!-- Price anchor: hire agents like staff -->
            <div class="mt-8">
              <span class="text-sm text-text-light-tertiary dark:text-text-dark-tertiary">Hire agents from </span>
              <span class="text-4xl font-black align-middle">${startFrom}</span><span class="text-lg text-text-light-secondary dark:text-text-dark-secondary">/mo each</span>
              <span class="block text-xs text-text-light-tertiary dark:text-text-dark-tertiary mt-1">one-time ${setup} setup · normal AI usage included · add or drop agents anytime</span>
            </div>

            <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
              <a href="#ai-team-roster" class="inline-flex items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-primary-blue to-primary-pink text-white px-8 py-3.5 text-sm font-semibold hover:shadow-[0_12px_36px_rgba(16,209,255,0.3)] transition-all duration-300">
                Meet & hire the team
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" /></svg>
              </a>
              <a href={BOOKING_URL} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 rounded-xl border border-primary-blue/40 text-primary-blue dark:text-blue-300 px-6 py-3.5 text-sm font-semibold hover:bg-primary-blue/5 transition-all duration-300">
                Book a call
              </a>
            </div>
          </div>
        </Container>
      </div>
    </header>

    <!-- Meet the team -->
    <Section id="ai-team-roster" variant="default">
      <Container>
        <div class="text-center max-w-2xl mx-auto mb-4">
          <h2 class="sf-bold text-2xl md:text-3xl font-bold">
            <span class="apple-gradient-text" data-colorful-title>Meet — and hire — your team</span>
          </h2>
          <p class="mt-3 text-base text-text-light-secondary dark:text-text-dark-secondary leading-relaxed">
            Each agent owns one job and does it well. Hire one and it reports straight to you — an email, a PDF, however you like it. Hire more and they hand work off to each other automatically. A flat monthly rate per agent, like staff, with normal AI usage included.
          </p>
        </div>

        <!-- Pipeline one-liner -->
        <p class="text-center text-sm text-text-light-tertiary dark:text-text-dark-tertiary mb-10">
          Eve researches → Elly writes → Eny designs → Mimi voices → Bap publishes → Upie manages the reviews that come back.
        </p>

        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 max-w-5xl mx-auto">
          {roster.map((a) => (
            <div class="rounded-2xl border border-light-tertiary dark:border-dark-accent bg-white dark:bg-dark-secondary p-6 flex flex-col items-center text-center hover:border-primary-blue/40 hover:shadow-lg transition-all duration-300">
              <div class="w-20 h-20 mb-4">
                <AgentAvatar agent={a.id} class="w-full h-full" />
              </div>
              <h3 class="text-lg font-bold text-text-light-primary dark:text-text-dark-primary">{a.name}</h3>
              <span class="text-[11px] font-semibold uppercase tracking-wide text-primary-blue dark:text-blue-300 mb-3">{a.role}</span>
              <p class="text-sm text-text-light-secondary dark:text-text-dark-secondary leading-relaxed flex-1">{a.does}</p>
              <div class="mt-4 leading-none">
                <span class="text-2xl font-black text-text-light-primary dark:text-text-dark-primary">${a.price}</span><span class="text-sm text-text-light-secondary dark:text-text-dark-secondary">/mo</span>
              </div>
              <a
                href="#contact"
                data-contact-context={`AI Team — hire ${a.name} (${a.role})`}
                class="mt-3 w-full inline-flex items-center justify-center rounded-xl border border-primary-blue/40 text-primary-blue dark:text-blue-300 px-4 py-2.5 text-sm font-semibold hover:bg-primary-blue/5 transition-all duration-300"
              >
                Hire {a.name}
              </a>
            </div>
          ))}
        </div>

        <!-- Whole-roster bundle -->
        <div class="mt-10 max-w-5xl mx-auto rounded-3xl border border-primary-blue/40 ring-1 ring-primary-blue/20 bg-gradient-to-br from-primary-blue/[0.06] via-transparent to-primary-pink/[0.06] p-6 sm:p-8">
          <div class="flex flex-col lg:flex-row items-center gap-6 lg:gap-8">
            <div class="flex -space-x-2 flex-shrink-0">
              {roster.map((a) => (
                <div class="w-11 h-11 rounded-full ring-2 ring-white dark:ring-dark-primary" title={`${a.name} — ${a.role}`}>
                  <AgentAvatar agent={a.id} class="w-full h-full" />
                </div>
              ))}
            </div>
            <div class="flex-1 text-center lg:text-left">
              <span class="inline-block bg-gradient-to-r from-primary-blue to-primary-pink text-white text-[11px] font-bold uppercase tracking-wide px-2.5 py-1 rounded-full mb-2">Best value</span>
              <h3 class="text-xl font-bold text-text-light-primary dark:text-text-dark-primary">Hire the whole team</h3>
              <p class="mt-1.5 text-sm text-text-light-secondary dark:text-text-dark-secondary leading-relaxed">
                All six agents, coordinated as one operation — ${bundleMo}/mo instead of ${alaCarte}/mo à la carte. You save ${bundleSave} every month.
              </p>
            </div>
            <div class="flex-shrink-0 text-center">
              <div class="text-2xl font-black text-text-light-primary dark:text-text-dark-primary leading-none">${bundleMo}<span class="text-sm font-semibold text-text-light-secondary dark:text-text-dark-secondary">/mo</span></div>
              <a href="#contact" data-contact-context="AI Team — full roster bundle" class="mt-3 inline-flex items-center justify-center gap-1.5 rounded-xl bg-gradient-to-r from-primary-blue to-primary-pink text-white px-5 py-2.5 text-sm font-semibold hover:shadow-[0_10px_30px_rgba(16,209,255,0.3)] transition-all">
                Hire all six
              </a>
            </div>
          </div>
        </div>

        <p class="mt-6 text-center text-xs text-text-light-tertiary dark:text-text-dark-tertiary max-w-2xl mx-auto leading-relaxed">
          One-time ${setup} setup builds and trains your team — however many agents you hire. Normal AI usage is included; unusually heavy usage is metered at cost and quoted before it ever hits a bill. Add or drop agents anytime. The Smart Website plan includes your first agent.
        </p>
      </Container>
    </Section>

    <!-- Human in the loop -->
    <Section id="ai-team-human" variant="alternate">
      <Container>
        <div class="max-w-3xl mx-auto rounded-2xl border border-light-tertiary dark:border-dark-accent bg-white dark:bg-dark-secondary p-8 text-center">
          <h2 class="sf-bold text-2xl md:text-3xl font-bold mb-4">
            <span class="apple-gradient-text" data-colorful-title>Not fully autonomous — on purpose</span>
          </h2>
          <p class="text-base text-text-light-secondary dark:text-text-dark-secondary leading-relaxed">
            The agents do the volume: drafting, designing, scheduling, monitoring. A person reviews the output and steps in where judgment matters — the phone calls, the verifications, the review appeals, the decisions AI should not make alone. You get the speed of automation without handing your brand to a robot.
          </p>
        </div>
      </Container>
    </Section>

    <!-- How it works -->
    <Section id="ai-team-steps" variant="alternate">
      <Container>
        <h2 class="sf-bold text-2xl md:text-3xl font-bold text-center mb-12">
          <span class="apple-gradient-text" data-colorful-title>How we build it for you</span>
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 max-w-6xl mx-auto">
          {steps.map((s) => (
            <div class="group relative overflow-hidden rounded-2xl border border-light-tertiary dark:border-dark-accent bg-white dark:bg-dark-secondary p-6 transition-all duration-300 hover:-translate-y-1 hover:border-primary-blue/40 hover:shadow-xl hover:shadow-primary-blue/10">
              <span aria-hidden="true" data-n={s.n} class="pointer-events-none absolute top-3 right-4 text-6xl font-black leading-none text-primary-blue/10 dark:text-blue-300/10 select-none after:content-[attr(data-n)]"></span>
              <div class="relative flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-primary-blue to-primary-pink text-white shadow-lg shadow-primary-blue/20">
                <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d={s.icon} />
                </svg>
              </div>
              <h3 class="relative mt-4 text-lg font-bold text-text-light-primary dark:text-text-dark-primary">{s.title}</h3>
              <p class="relative mt-2 text-sm text-text-light-secondary dark:text-text-dark-secondary leading-relaxed">{s.body}</p>
            </div>
          ))}
        </div>
      </Container>
    </Section>

    <!-- FAQ -->
    <Section id="ai-team-faq" variant="alternate">
      <Container>
        <div class="max-w-3xl mx-auto">
          <h2 class="sf-bold text-2xl md:text-3xl font-bold text-center mb-10">
            <span class="apple-gradient-text" data-colorful-title>Common questions</span>
          </h2>
          <div class="space-y-4">
            {aiTeamFaq.map((f) => (
              <div class="rounded-xl border border-light-tertiary dark:border-dark-accent bg-white dark:bg-dark-secondary p-5">
                <h3 class="font-semibold text-text-light-primary dark:text-text-dark-primary mb-2">{f.q}</h3>
                <p class="text-sm text-text-light-secondary dark:text-text-dark-secondary leading-relaxed">{f.a}</p>
              </div>
            ))}
          </div>
          <div class="text-center mt-12">
            <a href="#contact" data-contact-context="AI Team" class="inline-flex items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-primary-blue to-primary-pink text-white px-6 py-3 text-sm font-semibold hover:shadow-[0_12px_36px_rgba(16,209,255,0.3)] transition-all duration-300">
              Build my AI team
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
            </a>
          </div>
        </div>
      </Container>
    </Section>

    <ChatBox />
    <DockMenu />
  </main>
</BaseLayout>
