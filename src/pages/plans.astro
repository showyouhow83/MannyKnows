---
// Dedicated Plans & Pricing page — better for SEO and for linking in proposals
// and DMs than the homepage anchor. Reuses <PricingPlans /> so the tiers stay a
// single source of truth.
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import NavBar from '../components/navigation/NavBar.astro';
import Section from '../components/layout/Section.astro';
import Container from '../components/layout/Container.astro';
import DockMenu from '../components/navigation/DockMenu.astro';
import ChatBox from '../components/ui/ChatBox.astro';
import PricingPlans from '../components/sections/PricingPlans.astro';
import QuoteBlock from '../components/ui/QuoteBlock.astro';
import { getTestimonial } from '../data/testimonials';
import AgentAvatar from '../components/team/AgentAvatar.astro';
import { team, aiTeamStartingPrice } from '../data/aiTeam';

const aiTeamRoster = [...team].sort((a, b) => a.order - b.order);

const faqs = [
  {
    q: 'Can a plan be customized?',
    a: "Yes — every plan is a starting point. We tailor what's in it — and the price — to your business, so you're never paying for services you don't need.",
  },
  {
    q: "What if I don't have a website yet?",
    a: "That's what the plans are for — Smart Website (AI) and Online Store (AI) include designing and building your site or store, with no big upfront bill. Prefer to pay once as a one-time project instead? We do that too — see our products.",
  },
  {
    q: 'Is there a contract?',
    a: "Two options. Month-to-month: full price, cancel anytime. Yearly: pay the year upfront and get 2 months free — 10 months' worth for 12 months of service. Details are in our terms.",
  },
  {
    q: 'How do we start?',
    a: "Tell us what you're working with — a quick message or a call. We scope a plan together before anything's locked in.",
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout
  title="Plans & Pricing — Website, SEO & AI Retainers | MannyKnows"
  description="Monthly plans for Western Massachusetts businesses — a multilingual site with an AI booking agent, a full online store, business ads, or a full multimedia agency. Starting at $350/mo: Smart Website, Online Store, Business Ads & Multimedia Agency, each tailored to you."
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <main class="relative bg-light-primary dark:bg-dark-primary text-text-light-primary dark:text-text-dark-primary min-h-screen transition-colors duration-300">

    <header class="relative bg-gradient-to-t from-gray-50/50 via-gray-100/30 to-gray-50/20 dark:from-gray-900/60 dark:via-slate-800/40 dark:to-gray-900/30 transition-colors duration-300">
      <NavBar />
      <nav aria-label="breadcrumb" class="max-w-[1440px] mx-auto px-4 lg:px-6 pt-6 pb-4">
        <ol class="flex flex-wrap items-center gap-2 text-sm text-text-light-secondary dark:text-text-dark-secondary">
          <li><a href="/" class="hover:text-primary-blue transition-colors">Home</a></li>
          <li class="flex items-center"><span class="mx-2 text-text-light-tertiary dark:text-text-dark-tertiary">/</span><span class="text-text-light-primary dark:text-text-dark-primary font-medium">Plans</span></li>
        </ol>
      </nav>
      <div class="pb-12 px-4">
        <Container>
          <div class="text-center max-w-3xl mx-auto">
            <span class="inline-block bg-gradient-to-r from-primary-blue/10 via-purple-500/10 to-primary-pink/10 text-primary-blue px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider mb-4">Plans &amp; pricing</span>
            <h1 class="sf-bold apple-headline text-4xl md:text-5xl lg:text-6xl mb-6">
              <span class="apple-gradient-text" data-colorful-title>Plans that grow with you</span>
            </h1>
            <p class="text-base sm:text-xl text-text-light-secondary dark:text-text-dark-secondary leading-relaxed">
              Monthly plans, scoped to your business. Pick where you need help most — we tailor the scope and price, and you can move up or down any time. The numbers are where each plan starts.
            </p>
          </div>
        </Container>
      </div>
    </header>

    <Section id="plans-list" variant="default">
      <Container>
        <!-- Flagship: the AI Team (its own page, sold as a monthly retainer) -->
        <a href="/ai-team" class="group block max-w-6xl mx-auto mb-12 rounded-3xl border border-primary-blue/40 ring-1 ring-primary-blue/20 bg-gradient-to-br from-primary-blue/[0.06] via-transparent to-primary-pink/[0.06] p-6 sm:p-8 hover:shadow-[0_16px_50px_rgba(16,209,255,0.18)] transition-all duration-300">
          <div class="flex flex-col lg:flex-row items-center gap-6 lg:gap-8">
            <div class="flex flex-wrap justify-center -space-x-1.5 flex-shrink-0 max-w-[280px] lg:max-w-none">
              {aiTeamRoster.map((a) => (
                <div class="w-9 h-9 sm:w-11 sm:h-11 rounded-full ring-2 ring-primary-blue/40 bg-gradient-to-br from-primary-blue/10 to-primary-pink/10 overflow-hidden" title={`${a.name} — ${a.role}`}>
                  <AgentAvatar agent={a.id} class="w-full h-full" />
                </div>
              ))}
            </div>
            <div class="flex-1 text-center lg:text-left">
              <span class="inline-block bg-gradient-to-r from-primary-blue to-primary-pink text-white text-[11px] font-bold uppercase tracking-wide px-2.5 py-1 rounded-full mb-2">Flagship</span>
              <h2 class="text-xl sm:text-2xl font-bold text-text-light-primary dark:text-text-dark-primary">The AI Team — built for you, run on demand</h2>
              <p class="mt-1.5 text-sm text-text-light-secondary dark:text-text-dark-secondary leading-relaxed max-w-2xl">
                Ten AI specialists — front desk, research, copy, graphics &amp; video, voice, SEO, publishing, paid ads, engagement, and reporting — plus Manny, your manager, coordinating them all. Hire them like staff, one at a time or as a team, with a person watching the output. One-time $199 setup.
              </p>
            </div>
            <div class="flex-shrink-0 text-center">
              <div class="text-xs uppercase tracking-wide text-text-light-tertiary dark:text-text-dark-tertiary">Agents from</div>
              <div class="text-2xl font-black text-text-light-primary dark:text-text-dark-primary leading-none">${aiTeamStartingPrice.toLocaleString('en-US')}<span class="text-sm font-semibold text-text-light-secondary dark:text-text-dark-secondary">/mo each</span></div>
              <span class="mt-3 inline-flex items-center justify-center gap-1.5 rounded-xl bg-gradient-to-r from-primary-blue to-primary-pink text-white px-5 py-2.5 text-sm font-semibold transition-all">
                Meet the team
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
              </span>
            </div>
          </div>
        </a>

        <PricingPlans />
        <div class="max-w-2xl mx-auto mt-14">
          <QuoteBlock quote={getTestimonial('SL Painting')} align="center" />
        </div>
      </Container>
    </Section>

    <Section id="plans-faq" variant="default">
      <Container>
        <div class="max-w-3xl mx-auto">
          <h2 class="sf-bold text-2xl md:text-3xl font-bold text-center mb-10">
            <span class="apple-gradient-text" data-colorful-title>Common questions</span>
          </h2>
          <div class="space-y-4">
            {faqs.map((f) => (
              <div class="rounded-xl border border-light-tertiary dark:border-dark-accent bg-white dark:bg-dark-secondary p-5">
                <h3 class="font-semibold text-text-light-primary dark:text-text-dark-primary mb-2">{f.q}</h3>
                <p class="text-sm text-text-light-secondary dark:text-text-dark-secondary leading-relaxed">{f.a}</p>
              </div>
            ))}
          </div>

          <div class="text-center mt-12">
            <a href="#contact" class="inline-flex items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-primary-blue to-primary-pink text-white px-6 py-3 text-sm font-semibold transition-all duration-300">
              Build your plan
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
            </a>
          </div>
        </div>
      </Container>
    </Section>

    <ChatBox />
    <DockMenu />
  </main>
</BaseLayout>
