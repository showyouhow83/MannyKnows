---
// Terms of Service — reviewable template, styled to match the site.
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import MarqueeSimple from '../components/MarqueeSimple.astro';
import NavBar from '../components/navigation/NavBar.astro';
import Section from '../components/layout/Section.astro';
import Container from '../components/layout/Container.astro';
import DockMenu from '../components/navigation/DockMenu.astro';
import ChatBox from '../components/ui/ChatBox.astro';

const effectiveDate = 'June 2, 2026';
---

<BaseLayout title="Terms of Service | MannyKnows">
  <main class="relative bg-light-primary dark:bg-dark-primary text-text-light-primary dark:text-text-dark-primary min-h-screen transition-colors duration-300">
    <MarqueeSimple />

    <header class="relative bg-gradient-to-t from-gray-50/50 via-gray-100/30 to-gray-50/20 dark:from-gray-900/60 dark:via-slate-800/40 dark:to-gray-900/30 transition-colors duration-300">
      <NavBar />
      <nav aria-label="breadcrumb" class="max-w-[1440px] mx-auto px-4 lg:px-6 pt-24 pb-4">
        <ol class="flex flex-wrap items-center gap-2 text-sm text-text-light-secondary dark:text-text-dark-secondary">
          <li><a href="/" class="hover:text-primary-blue transition-colors">Home</a></li>
          <li class="flex items-center"><span class="mx-2 text-text-light-tertiary dark:text-text-dark-tertiary">/</span><span class="text-text-light-primary dark:text-text-dark-primary font-medium">Terms of Service</span></li>
        </ol>
      </nav>
      <div class="pb-10 px-4">
        <Container>
          <div class="max-w-3xl mx-auto text-center">
            <span class="inline-block bg-gradient-to-r from-primary-blue/10 via-purple-500/10 to-primary-pink/10 text-primary-blue px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider mb-4">Legal</span>
            <h1 class="sf-bold apple-headline text-4xl md:text-5xl lg:text-6xl mb-5 leading-tight">
              <span class="apple-gradient-text" data-colorful-title>Terms of Service</span>
            </h1>
            <p class="text-lg text-text-light-secondary dark:text-text-dark-secondary leading-relaxed">The terms that govern your use of MannyKnows.</p>
            <p class="mt-3 text-sm text-text-light-tertiary dark:text-text-dark-tertiary">Effective date: {effectiveDate}</p>
          </div>
        </Container>
      </div>
    </header>

    <Section id="terms" variant="default">
      <Container>
        <article class="legal-prose max-w-3xl mx-auto">
          <div class="legal-notice">
            <strong>Template notice.</strong> These Terms are a starting point tailored to MannyKnows and have <em>not</em> been reviewed by a lawyer. Review the items in [brackets] — especially governing law and contact details — before relying on them.
          </div>

          <p>Welcome to MannyKnows. These Terms of Service ("Terms") govern your access to and use of <a href="/">mannyknows.com</a> (the "Site") and any related content, tools, and services we provide (together, the "Services"). By using the Site, you agree to these Terms. If you do not agree, please do not use the Site.</p>

          <h2>1. Who may use the Services</h2>
          <p>You must be able to form a binding contract to use the Services. If you use the Services on behalf of an organization, you represent that you are authorized to accept these Terms on its behalf.</p>

          <h2>2. The Services</h2>
          <p>The Site provides information about MannyKnows' offerings and lets you contact us, subscribe to our newsletter, and interact with an AI chat assistant. Any specific project or paid engagement is governed by a separate written agreement between you and MannyKnows; if that agreement conflicts with these Terms, the separate agreement controls for that engagement.</p>

          <h2>3. AI chat assistant</h2>
          <p>Our chat assistant uses automated, AI-generated responses. It may be inaccurate, incomplete, or out of date, and it is provided for general information only — it is not professional, legal, financial, or other advice. Do not submit sensitive personal information through the chat, and verify anything important before relying on it.</p>

          <h2>4. Acceptable use</h2>
          <p>When using the Services, you agree not to:</p>
          <ul>
            <li>Break the law or infringe the rights of others.</li>
            <li>Submit false, misleading, or others' personal information without permission.</li>
            <li>Attempt to disrupt, overload, probe, or gain unauthorized access to the Site or its systems.</li>
            <li>Introduce malware, scrape or harvest data without permission, or circumvent security or rate-limiting measures.</li>
            <li>Use the Services to send spam or for any abusive or harmful purpose.</li>
          </ul>

          <h2>5. Intellectual property</h2>
          <p>The Site and its content — including text, graphics, logos, and design — are owned by MannyKnows or its licensors and are protected by intellectual-property laws. We grant you a limited, non-exclusive, non-transferable license to access and use the Site for its intended purpose. You may not copy, modify, distribute, or create derivative works without our permission, except as allowed by law.</p>

          <h2>6. Your submissions</h2>
          <p>When you send us content through a form, the chat assistant, or otherwise, you keep your rights in it but grant MannyKnows a worldwide, royalty-free license to use that content to operate and improve the Services and to respond to you. Do not submit anything you do not have the right to share, and do not share confidential information you do not want us to use for these purposes.</p>

          <h2>7. Third-party links and services</h2>
          <p>The Site may link to or rely on third-party websites and services we do not control. We are not responsible for their content, policies, or practices, and your use of them is at your own risk.</p>

          <h2>8. Disclaimers</h2>
          <p>The Services are provided "as is" and "as available," without warranties of any kind, whether express or implied, including implied warranties of merchantability, fitness for a particular purpose, and non-infringement. We do not warrant that the Services will be uninterrupted, secure, error-free, or that any information provided is accurate or complete.</p>

          <h2>9. Limitation of liability</h2>
          <p>To the fullest extent permitted by law, MannyKnows will not be liable for any indirect, incidental, special, consequential, or punitive damages, or any loss of profits, data, or goodwill, arising from your use of the Services. [Consider adding a liability cap, e.g., the amount you paid us in the prior 12 months, with the help of counsel.]</p>

          <h2>10. Indemnification</h2>
          <p>You agree to indemnify and hold harmless MannyKnows from any claims, damages, liabilities, and expenses arising out of your use of the Services or your violation of these Terms or applicable law.</p>

          <h2>11. Changes to the Services and Terms</h2>
          <p>We may modify or discontinue the Services at any time. We may also update these Terms; the updated version will be posted here with a revised "Effective date." Your continued use of the Site after changes take effect means you accept the updated Terms.</p>

          <h2>12. Governing law</h2>
          <p>These Terms are governed by the laws of [your state/country], without regard to its conflict-of-laws rules, and any disputes will be resolved in the courts located in [your jurisdiction]. [Confirm with counsel; you may want an arbitration or dispute-resolution clause.]</p>

          <h2>13. Contact us</h2>
          <p>Questions about these Terms? Reach us at <a href="mailto:hello@mannyknows.com">hello@mannyknows.com</a> [update with your preferred contact email], or through the <a href="/#about">contact form</a> on our Site.</p>
        </article>

        <div class="max-w-3xl mx-auto mt-12 pt-8 border-t border-light-tertiary dark:border-dark-accent flex items-center justify-between gap-4">
          <a href="/" class="inline-flex items-center gap-2 text-primary-blue font-medium group">
            <svg class="w-4 h-4 rotate-180 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            Back home
          </a>
          <a href="/privacy" class="inline-flex items-center gap-2 text-primary-blue font-medium group">
            Privacy Policy
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>
      </Container>
    </Section>

    <ChatBox />
    <DockMenu />
  </main>
</BaseLayout>

<style>
  .legal-prose { color: inherit; font-size: 1.05rem; line-height: 1.8; }
  .legal-prose :global(h2) { font-size: 1.5rem; font-weight: 700; margin: 2.25rem 0 0.75rem; line-height: 1.3; }
  .legal-prose :global(h3) { font-size: 1.15rem; font-weight: 700; margin: 1.5rem 0 0.5rem; }
  .legal-prose :global(p) { margin: 0 0 1.25rem; }
  .legal-prose :global(ul), .legal-prose :global(ol) { margin: 0 0 1.25rem; padding-left: 1.5rem; }
  .legal-prose :global(li) { margin: 0.4rem 0; }
  .legal-prose :global(ul) { list-style: disc; }
  .legal-prose :global(ol) { list-style: decimal; }
  .legal-prose :global(a) { color: #0071e3; text-decoration: underline; text-underline-offset: 2px; }
  .legal-prose :global(a:hover) { color: #ff4faa; }
  .legal-prose :global(strong) { font-weight: 700; }
  .legal-notice { background: rgba(245, 158, 11, 0.10); border: 1px solid rgba(245, 158, 11, 0.35); color: inherit; border-radius: 12px; padding: 1rem 1.25rem; margin: 0 0 2rem; font-size: 0.95rem; line-height: 1.6; }
</style>
