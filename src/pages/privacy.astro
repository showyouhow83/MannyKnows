---
// Privacy Policy — styled to match the site.
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import MarqueeSimple from '../components/MarqueeSimple.astro';
import NavBar from '../components/navigation/NavBar.astro';
import Section from '../components/layout/Section.astro';
import Container from '../components/layout/Container.astro';
import DockMenu from '../components/navigation/DockMenu.astro';
import ChatBox from '../components/ui/ChatBox.astro';

const effectiveDate = 'July 14, 2026';
---

<BaseLayout title="Privacy Policy | MannyKnows">
  <main class="relative bg-light-primary dark:bg-dark-primary text-text-light-primary dark:text-text-dark-primary min-h-screen transition-colors duration-300">
    <MarqueeSimple />

    <header class="relative bg-gradient-to-t from-gray-50/50 via-gray-100/30 to-gray-50/20 dark:from-gray-900/60 dark:via-slate-800/40 dark:to-gray-900/30 transition-colors duration-300">
      <NavBar />
      <nav aria-label="breadcrumb" class="max-w-[1440px] mx-auto px-4 lg:px-6 pt-24 pb-4">
        <ol class="flex flex-wrap items-center gap-2 text-sm text-text-light-secondary dark:text-text-dark-secondary">
          <li><a href="/" class="hover:text-primary-blue transition-colors">Home</a></li>
          <li class="flex items-center"><span class="mx-2 text-text-light-tertiary dark:text-text-dark-tertiary">/</span><span class="text-text-light-primary dark:text-text-dark-primary font-medium">Privacy Policy</span></li>
        </ol>
      </nav>
      <div class="pb-10 px-4">
        <Container>
          <div class="max-w-3xl mx-auto text-center">
            <span class="inline-block bg-gradient-to-r from-primary-blue/10 via-purple-500/10 to-primary-pink/10 text-primary-blue px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider mb-4">Legal</span>
            <h1 class="sf-bold apple-headline text-4xl md:text-5xl lg:text-6xl mb-5 leading-tight">
              <span class="apple-gradient-text" data-colorful-title>Privacy Policy</span>
            </h1>
            <p class="text-lg text-text-light-secondary dark:text-text-dark-secondary leading-relaxed">How MannyKnows collects, uses, and protects your information.</p>
            <p class="mt-3 text-sm text-text-light-tertiary dark:text-text-dark-tertiary">Effective date: {effectiveDate}</p>
          </div>
        </Container>
      </div>
    </header>

    <Section id="privacy" variant="default">
      <Container>
        <article class="legal-prose max-w-3xl mx-auto">
          <p>This Privacy Policy explains how MannyKnows ("MannyKnows," "we," "us," or "our") — the trade name of Manuel Medina Rodriguez, a Springfield, Massachusetts business serving Western Massachusetts — collects, uses, and shares information when you visit <a href="/">mannyknows.com</a> (the "Site") or use our services.</p>

          <h2>1. Information we collect</h2>
          <h3>Information you provide</h3>
          <ul>
            <li><strong>Contact form:</strong> your name, email address, details about your business or website, and your message.</li>
            <li><strong>Newsletter:</strong> your email address.</li>
            <li><strong>AI chat assistant:</strong> if you use our chat assistant when it is offered on the Site, the messages you send and any details you choose to share in the conversation (chat transcripts).</li>
            <li><strong>Other communications:</strong> anything you send us directly (for example, by email or phone).</li>
          </ul>
          <h3>Information collected automatically</h3>
          <ul>
            <li><strong>Basic analytics:</strong> aggregate usage data such as pages viewed and traffic to the Site.</li>
            <li><strong>Device and connection data:</strong> when you submit a form, we record technical details such as your IP address and browser type alongside the submission to prevent abuse.</li>
          </ul>

          <h2>2. How we use your information</h2>
          <ul>
            <li>To respond to your inquiries and provide the services you request.</li>
            <li>To send the newsletter and updates you have subscribed to, and to confirm your submissions by email.</li>
            <li>To operate, maintain, secure, and improve the Site and our services.</li>
            <li>To detect, prevent, and address fraud, abuse, and security issues (for example, rate limiting and request validation).</li>
            <li>To comply with legal obligations and enforce our terms.</li>
          </ul>

          <h2>3. Where your information is stored</h2>
          <p>The Site runs on Cloudflare's global network (Cloudflare Workers). Information you submit — such as contact-form submissions, newsletter signups, and chat transcripts — is stored in Cloudflare's KV and R2 storage services.</p>

          <h2>4. How we share information</h2>
          <p>We do <strong>not</strong> sell your personal information. We share it only as described here:</p>
          <ul>
            <li><strong>Cloudflare:</strong> hosting, infrastructure, and data storage for the Site.</li>
            <li><strong>Resend:</strong> email delivery — notification emails to us and confirmation emails to you.</li>
            <li><strong>Twilio:</strong> SMS and phone services, where a client engagement uses them.</li>
            <li><strong>AI provider:</strong> if you use our chat assistant, your chat messages are processed by the AI provider that powers it in order to generate responses.</li>
            <li><strong>Legal and safety:</strong> when required by law, or to protect the rights, safety, and property of MannyKnows, our users, or others.</li>
            <li><strong>Business transfers:</strong> in connection with a merger, acquisition, or sale of assets, subject to this Policy.</li>
          </ul>

          <h2>5. Cookies and analytics</h2>
          <p>We keep this minimal. The Site uses essential technologies needed to function — such as security tokens that protect our forms — and we collect basic analytics to understand how the Site is used. You can control cookies through your browser settings; disabling them may affect some features.</p>

          <h2>6. Data retention</h2>
          <p>We keep personal information only as long as needed for the purposes described in this Policy, to comply with our legal obligations, resolve disputes, and enforce our agreements. You can ask us to delete your information at any time using the contact details below.</p>

          <h2>7. Your rights and choices</h2>
          <ul>
            <li><strong>Newsletter:</strong> you can unsubscribe at any time using the link in our emails or by contacting us.</li>
            <li><strong>Access, correction, deletion:</strong> depending on where you live, you may have the right to access, correct, delete, or port your personal information, or to object to or restrict certain processing.</li>
            <li><strong>How to exercise:</strong> contact us using the details below and we will respond as required by applicable law.</li>
          </ul>

          <h2>8. Security</h2>
          <p>We use reasonable technical and organizational measures to protect your information, including rate limiting, input validation, and request-forgery protections on our forms. No method of transmission or storage is completely secure, so we cannot guarantee absolute security.</p>

          <h2>9. Children's privacy</h2>
          <p>The Site is not directed to children under 13, and we do not knowingly collect personal information from them. If you believe a child has provided us information, please contact us and we will delete it.</p>

          <h2>10. Third-party links</h2>
          <p>The Site may link to third-party websites and services we do not control. Their privacy practices are governed by their own policies, and we are not responsible for them.</p>

          <h2>11. International users</h2>
          <p>We are based in the United States, and the Site is delivered through Cloudflare's global network, so information may be processed on servers outside the country where you live.</p>

          <h2>12. Changes to this Policy</h2>
          <p>We may update this Policy from time to time. We will post the updated version here and revise the "Effective date" above. Material changes may be communicated through the Site or by email.</p>

          <h2>13. Contact us</h2>
          <p>Questions about this Policy or your information? Reach us at <a href="mailto:mk@mannyknows.com">mk@mannyknows.com</a>, call <a href="tel:+14133618451">(413)&nbsp;361-8451</a>, or use the <a href="/#about">contact form</a> on our Site. MannyKnows is operated by Manuel Medina Rodriguez in Springfield, Massachusetts.</p>
        </article>

        <div class="max-w-3xl mx-auto mt-12 pt-8 border-t border-light-tertiary dark:border-dark-accent flex items-center justify-between gap-4">
          <a href="/" class="inline-flex items-center gap-2 text-primary-blue font-medium group">
            <svg class="w-4 h-4 rotate-180 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            Back home
          </a>
          <a href="/terms" class="inline-flex items-center gap-2 text-primary-blue font-medium group">
            Terms of Service
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>
      </Container>
    </Section>

    <ChatBox />
    <DockMenu />
  </main>
</BaseLayout>

<style>
  .legal-prose { color: inherit; font-size: 1.05rem; line-height: 1.8; }
  .legal-prose :global(h2) { font-size: 1.5rem; font-weight: 700; margin: 2.25rem 0 0.75rem; line-height: 1.3; }
  .legal-prose :global(h3) { font-size: 1.15rem; font-weight: 700; margin: 1.5rem 0 0.5rem; }
  .legal-prose :global(p) { margin: 0 0 1.25rem; }
  .legal-prose :global(ul), .legal-prose :global(ol) { margin: 0 0 1.25rem; padding-left: 1.5rem; }
  .legal-prose :global(li) { margin: 0.4rem 0; }
  .legal-prose :global(ul) { list-style: disc; }
  .legal-prose :global(ol) { list-style: decimal; }
  .legal-prose :global(a) { color: #0071e3; text-decoration: underline; text-underline-offset: 2px; }
  .legal-prose :global(a:hover) { color: #ff4faa; }
  .legal-prose :global(strong) { font-weight: 700; }
</style>
